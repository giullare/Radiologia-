@model RadiologiaAppNew.Models.NullaOsta
@using RadiologiaAppNew.Enums
@{
    Layout = "_Layout";
    var isEdit = ViewBag.IsEdit == true;
    ViewData["Title"] = isEdit ? "Modifica Nulla Osta" : "Nuovo Nulla Osta";
    ViewData["BreadcrumbParent"] = "Sorveglianza Fisica";
    int appId = ViewBag.ApparecchiaturaId ?? 0;
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-shield-check me-2 text-primary"></i>
            @(isEdit ? "Modifica Nulla Osta" : "Nuovo Nulla Osta")
        </h1>
        <p class="page-subtitle">@ViewBag.ApparecchiaturaDescrizione</p>
    </div>
    <div class="page-actions">
        <a href="/Apparecchiature/Detail/@appId?tab=adempimenti"
           class="btn btn-ghost">
            <i class="bi bi-arrow-left"></i> Torna alla scheda
        </a>
    </div>
</div>

<form asp-action="@(isEdit ? "EditNullaOsta" : "NuovoNullaOsta")"
      asp-controller="Adempimenti"
      asp-route-id="@(isEdit ? Model.Id : (int?)null)"
      method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ApparecchiaturaId" />
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-radiologia alert-danger mb-4">
            <i class="bi bi-exclamation-circle alert-icon"></i>
            <div>
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div style="font-size:0.85rem">@e.ErrorMessage</div>
                }
            </div>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">

            <div class="form-section">
                <div class="form-section-header">
                    <i class="bi bi-shield-check text-primary"></i>
                    <h4 class="form-section-title">Dati Nulla Osta</h4>
                </div>
                <div class="form-section-body">
                    <div class="row g-3">

                        <!-- Tipo NO -->
                        <div class="col-md-4">
                            <label asp-for="Tipo" class="form-label"></label>
                            <div class="d-flex gap-2">
                                @foreach (var t in Enum.GetValues<TipoNullaOsta>())
                                {
                                    <div style="display:flex;align-items:center;gap:8px;
                                                padding:8px 14px;flex:1;
                                                border:1.5px solid var(--neutral-200);
                                                border-radius:8px;cursor:pointer;
                                                background:white;"
                                         id="tipoNoCard_@t"
                                         onclick="selezionaTipoNo('@t', this)">
                                        <input type="radio" name="Tipo" value="@t"
                                               id="radioTipo_@t"
                                               @(Model.Tipo == t ? "checked" : "")
                                               style="cursor:pointer;" />
                                        <label for="radioTipo_@t"
                                               style="cursor:pointer;font-weight:600;
                                                      font-size:0.875rem;margin:0;">
                                            @t
                                        </label>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="Tipo" class="text-danger"
                                  style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Numero" class="form-label"></label>
                            <input asp-for="Numero" class="form-control"
                                   placeholder="Numero Nulla Osta" />
                            <span asp-validation-for="Numero"
                                  class="text-danger" style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="DataRilascio" class="form-label"></label>
                            <input asp-for="DataRilascio" type="date" class="form-control" />
                            <span asp-validation-for="DataRilascio"
                                  class="text-danger" style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EnteRilascio" class="form-label"></label>
                            <input asp-for="EnteRilascio" class="form-control"
                                   placeholder="Es. ASL, ISIN, Prefettura" />
                            <span asp-validation-for="EnteRilascio"
                                  class="text-danger" style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="DataScadenza" class="form-label"></label>
                            <input asp-for="DataScadenza" type="date" class="form-control" />
                            <div class="form-text">Lascia vuoto se permanente</div>
                        </div>

                        <!-- Stato — solo Valido e Rinnovo -->
                        <div class="col-md-4">
                            <label asp-for="Stato" class="form-label"></label>
                            <div class="d-flex gap-2 flex-wrap">
                                @{
                                    var statiNo = new[]
                                    {
                                        (StatoNullaOsta.Valido,   "Valido",   "badge-ok",      "bi-check-circle"),
                                        (StatoNullaOsta.InRinnovo,"Rinnovo",  "badge-warning", "bi-arrow-repeat"),
                                    };
                                }
                                @foreach (var (val, lbl, cls, icon) in statiNo)
                                {
                                    <button type="button"
                                            id="statoBtn_@val"
                                            class="stato-no-btn @(Model.Stato == val ? "active" : "")"
                                            data-val="@val"
                                            onclick="selezionaStato('@val')">
                                        <i class="bi @icon me-1"></i> @lbl
                                    </button>
                                }
                                <input type="hidden" asp-for="Stato" id="hiddenStato" />
                            </div>
                            <span asp-validation-for="Stato" class="text-danger"
                                  style="font-size:0.775rem"></span>
                        </div>

                        <!-- File Nulla Osta -->
                        <div class="col-12">
                            <label class="form-label">File</label>
                            @if (isEdit && !string.IsNullOrEmpty(ViewBag.FileAttuale as string))
                            {
                                <div class="mb-2">
                                    <a href="@ViewBag.FileAttuale" target="_blank"
                                       class="btn btn-ghost btn-sm">
                                        <i class="bi bi-file-earmark"></i> File attuale
                                    </a>
                                </div>
                            }
                            <input type="file" name="fileNullaOsta" class="form-control"
                                   accept=".pdf,.jpg,.jpeg,.png" />
                            <div class="form-text">
                                Documento del Nulla Osta rilasciato dall'ente competente
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Note" class="form-label"></label>
                            <textarea asp-for="Note" class="form-control" rows="3"
                                      placeholder="Note aggiuntive, condizioni, prescrizioni...">
                            </textarea>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header" style="background:var(--primary);color:white;">
                    <h3 class="card-title" style="color:white;">
                        <i class="bi bi-shield-check me-2"></i>Info
                    </h3>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div style="font-size:0.78rem;font-weight:700;
                                    text-transform:uppercase;
                                    color:var(--neutral-500);margin-bottom:6px">
                            Tipo NO selezionato
                        </div>
                        <div class="fw-700" id="infoTipoNO" style="font-size:1rem">
                            @Model.Tipo
                        </div>
                    </div>
                    <hr class="divider" />
                    <p style="font-size:0.82rem;color:var(--neutral-600)">
                        <strong>Tipo A:</strong> sorgenti sigillate o generatori.<br />
                        <strong>Tipo B:</strong> sorgenti non sigillate.<br />
                        <strong>Rinnovo:</strong> NO in corso di rinnovo.
                    </p>
                    <hr class="divider" />
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle"></i>
                        @(isEdit ? "Aggiorna" : "Salva Nulla Osta")
                    </button>
                    <a href="/Apparecchiature/Detail/@appId?tab=adempimenti"
                       class="btn btn-ghost w-100 mt-2">Annulla</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
// Init: colora card selezionata
document.addEventListener('DOMContentLoaded', () => {
    const checked = document.querySelector('input[name="Tipo"]:checked');
    if (checked) {
        document.getElementById('tipoNoCard_' + checked.value)
            ?.style.setProperty('border-color', 'var(--primary)');
    }
    const stato = document.getElementById('hiddenStato')?.value;
    if (stato) aggiornaStatoBtn(stato);
});

function selezionaTipoNo(val, container) {
    document.querySelectorAll('[id^="tipoNoCard_"]').forEach(c => {
        c.style.borderColor = 'var(--neutral-200)';
        c.style.background  = 'white';
    });
    container.style.borderColor = 'var(--primary)';
    container.style.background  = 'rgba(27,79,114,0.04)';
    const radio = document.getElementById('radioTipo_' + val);
    if (radio) radio.checked = true;
    document.getElementById('infoTipoNO').textContent = val;
}

function selezionaStato(val) {
    document.getElementById('hiddenStato').value = val;
    aggiornaStatoBtn(val);
}

function aggiornaStatoBtn(val) {
    document.querySelectorAll('.stato-no-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('statoBtn_' + val)?.classList.add('active');
}
</script>
<style>
.stato-no-btn {
    padding: 6px 14px;
    border-radius: 20px;
    border: 1.5px solid var(--neutral-200);
    background: white;
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--neutral-600);
    transition: all .15s;
}
.stato-no-btn[data-val="Valido"].active   { background:#D5F5E3;border-color:#1E8449;color:#1E8449; }
.stato-no-btn[data-val="InRinnovo"].active { background:#FEF9E7;border-color:#B7950B;color:#B7950B; }
</style>
}
