@model RadiologiaAppNew.Models.NotificaPratica
@{
    Layout = "_Layout";
    var isEdit = ViewBag.IsEdit == true;
    ViewData["Title"] = isEdit ? "Modifica Notifica di Pratica" : "Nuova Notifica di Pratica";
    ViewData["BreadcrumbParent"] = "Sorveglianza Fisica";
    int appId = ViewBag.ApparecchiaturaId ?? 0;
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-send me-2 text-primary"></i>
            @(isEdit ? "Modifica Notifica di Pratica" : "Nuova Notifica di Pratica")
        </h1>
        <p class="page-subtitle">@ViewBag.ApparecchiaturaDescrizione</p>
    </div>
    <div class="page-actions">
        <a href="/Apparecchiature/Detail/@appId?tab=adempimenti"
           class="btn btn-ghost">
            <i class="bi bi-arrow-left"></i> Torna alla scheda
        </a>
    </div>
</div>

<form asp-action="@(isEdit ? "EditNotifica" : "NuovaNotifica")"
      asp-controller="Adempimenti"
      asp-route-id="@(isEdit ? Model.Id : (int?)null)"
      method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ApparecchiaturaId" />
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-radiologia alert-danger mb-4">
            <i class="bi bi-exclamation-circle alert-icon"></i>
            <div>
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div style="font-size:0.85rem">@e.ErrorMessage</div>
                }
            </div>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">

            <div class="form-section">
                <div class="form-section-header">
                    <i class="bi bi-send text-primary"></i>
                    <h4 class="form-section-title">Dati Notifica di Pratica</h4>
                </div>
                <div class="form-section-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label asp-for="NumeroProtocolloPec" class="form-label">
                                Numero Protocollo
                            </label>
                            <input asp-for="NumeroProtocolloPec" class="form-control"
                                   placeholder="Es. 2025/001234" />
                            <span asp-validation-for="NumeroProtocolloPec"
                                  class="text-danger" style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="DataNotifica" class="form-label"></label>
                            <input asp-for="DataNotifica" type="date" class="form-control" />
                            <span asp-validation-for="DataNotifica"
                                  class="text-danger" style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-md-9">
                            <label asp-for="EnteDestinatario" class="form-label"></label>
                            <input asp-for="EnteDestinatario" class="form-control"
                                   placeholder="Es. ASL competente, ISIN" />
                            <span asp-validation-for="EnteDestinatario"
                                  class="text-danger" style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label">File Notifica</label>
                            @if (isEdit && !string.IsNullOrEmpty(ViewBag.FileAttuale as string))
                            {
                                <div class="mb-2">
                                    <a href="@ViewBag.FileAttuale" target="_blank"
                                       class="btn btn-ghost btn-sm">
                                        <i class="bi bi-file-earmark"></i> File attuale — clicca per vedere
                                    </a>
                                </div>
                            }
                            <input type="file" name="fileNotifica" class="form-control"
                                   accept=".pdf,.jpg,.jpeg,.png,.docx" />
                            <div class="form-text">
                                Documento di notifica (PEC, ricevuta, allegati)
                            </div>
                        </div>

                        <div class="col-12"><hr class="divider" /></div>

                        <div class="col-md-3">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="InviatoRspp" type="checkbox"
                                       class="form-check-input"
                                       style="width:2.5em;height:1.3em;"
                                       onchange="onRsppChange(this)" />
                                <label asp-for="InviatoRspp" class="form-check-label ms-2">
                                    Inviato all'RSPP
                                </label>
                            </div>
                        </div>

                        <div class="col-md-3" id="divDataRspp"
                             style="@(Model.InviatoRspp ? "" : "display:none")">
                            <label asp-for="DataInvioRspp" class="form-label"></label>
                            <input asp-for="DataInvioRspp" type="date" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Note" class="form-label"></label>
                            <textarea asp-for="Note" class="form-control" rows="3"
                                      placeholder="Note aggiuntive..."></textarea>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header" style="background:var(--primary);color:white;">
                    <h3 class="card-title" style="color:white;">
                        <i class="bi bi-info-circle me-2"></i>Info
                    </h3>
                </div>
                <div class="card-body">
                    <p style="font-size:0.85rem;color:var(--neutral-600)">
                        La Notifica di Pratica deve essere inviata agli organi
                        competenti via PEC prima dell'entrata in uso
                        dell'apparecchiatura (art. 46 D.Lgs. 101/20).
                    </p>
                    <hr class="divider" />
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle"></i>
                        @(isEdit ? "Aggiorna" : "Salva Notifica")
                    </button>
                    <a href="/Apparecchiature/Detail/@appId?tab=adempimenti"
                       class="btn btn-ghost w-100 mt-2">Annulla</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
function onRsppChange(cb) {
    document.getElementById('divDataRspp').style.display =
        cb.checked ? 'block' : 'none';
}
</script>
}
