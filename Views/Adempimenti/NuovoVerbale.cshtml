@model RadiologiaAppNew.Models.Verbale
@{
    Layout = "_Layout";
    var isEdit = ViewBag.IsEdit == true;
    ViewData["Title"] = isEdit ? "Modifica Sopralluogo" : "Nuovo Sopralluogo";
    ViewData["BreadcrumbParent"] = "Sopralluoghi";
    int appId = ViewBag.ApparecchiaturaId ?? 0;

    // Helper per render campo SI/NO
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-journal-text me-2 text-primary"></i>
            @(isEdit ? "Modifica Sopralluogo" : "Nuovo Sopralluogo")
        </h1>
        <p class="page-subtitle">@ViewBag.ApparecchiaturaDescrizione</p>
    </div>
    <div class="page-actions">
        <a href="/Apparecchiature/Detail/@appId?tab=adempimenti"
           class="btn btn-ghost">
            <i class="bi bi-arrow-left"></i> Torna alla scheda
        </a>
    </div>
</div>

<form asp-action="@(isEdit ? "EditVerbale" : "CreateVerbale")"
      asp-controller="Adempimenti"
      asp-route-id="@(isEdit ? Model.Id : (int?)null)"
      method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ApparecchiaturaId" />
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-radiologia alert-danger mb-4">
            <i class="bi bi-exclamation-circle alert-icon"></i>
            <div>
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div style="font-size:0.85rem">@e.ErrorMessage</div>
                }
            </div>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">

            <!-- ══ DATI SOPRALLUOGO ══════════════════════════════ -->
            <div class="form-section mb-4">
                <div class="form-section-header">
                    <i class="bi bi-journal-text text-primary"></i>
                    <h4 class="form-section-title">Dati Sopralluogo</h4>
                </div>
                <div class="form-section-body">
                    <div class="row g-3">

                        <div class="col-md-3">
                            <label asp-for="DataSopralluogo" class="form-label"></label>
                            <input asp-for="DataSopralluogo" type="date" class="form-control" />
                            <span asp-validation-for="DataSopralluogo"
                                  class="text-danger" style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-md-9">
                            <label asp-for="Partecipanti" class="form-label"></label>
                            <input asp-for="Partecipanti" class="form-control"
                                   placeholder="Nomi dei partecipanti al sopralluogo" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Oggetto" class="form-label"></label>
                            <input asp-for="Oggetto" class="form-control"
                                   placeholder="Oggetto del sopralluogo" />
                            <span asp-validation-for="Oggetto"
                                  class="text-danger" style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Rilievi" class="form-label"></label>
                            <textarea asp-for="Rilievi" class="form-control" rows="4"
                                      placeholder="Descrivi rilievi e osservazioni..."></textarea>
                            <span asp-validation-for="Rilievi"
                                  class="text-danger" style="font-size:0.775rem"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="NonConformita" class="form-label"></label>
                            <textarea asp-for="NonConformita" class="form-control" rows="3"
                                      placeholder="Non conformità rilevate (se presenti)..."></textarea>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="AzioniCorrettive" class="form-label"></label>
                            <textarea asp-for="AzioniCorrettive" class="form-control" rows="3"
                                      placeholder="Azioni correttive richieste..."></textarea>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ScadenzaAzioni" class="form-label"></label>
                            <input asp-for="ScadenzaAzioni" type="date" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Stato" class="form-label"></label>
                            <select asp-for="Stato" class="form-select">
                                <option value="Aperto">Aperto</option>
                                <option value="Chiuso">Chiuso</option>
                                <option value="InAttesaAzioni">In Attesa Azioni</option>
                            </select>
                        </div>

                        <div class="col-md-4" id="divDataChiusura"
                             style="@(Model.Stato == "Chiuso" ? "" : "display:none")">
                            <label asp-for="DataChiusura" class="form-label"></label>
                            <input asp-for="DataChiusura" type="date" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">File Verbale</label>
                            <input type="file" name="fileVerbale" class="form-control"
                                   accept=".pdf,.docx,.jpg,.png" />
                        </div>

                    </div>
                </div>
            </div>

            <!-- ══ SPECIFICHE SOPRALLUOGO ════════════════════════ -->
            <div class="form-section">
                <div class="form-section-header">
                    <i class="bi bi-clipboard2-check text-primary"></i>
                    <h4 class="form-section-title">Specifiche Sopralluogo</h4>
                </div>
                <div class="form-section-body">

                    @{
                        // Helper locale per render riga SI/NO
                        string SiNoVal(bool? v) => v == true ? "true" : v == false ? "false" : "";
                    }

                    <!-- ── Campi generali ─────────────────────── -->
                    <div class="mb-4">
                        <div class="specifiche-group-title">Campi Generali</div>
                        @{ RenderSiNoRow("PresenzaDosimetroAmbientale",
                               "Presenza dosimetro ambientale",
                               Model.PresenzaDosimetroAmbientale); }
                        @{ RenderSiNoRow("CorrettezzaDosimetroAmbientale",
                               "Correttezza dosimetro ambientale (nome/periodo/posizionamento)",
                               Model.CorrettezzaDosimetroAmbientale); }
                        @{ RenderSiNoRow("PresenzaNormeRadioprotezione",
                               "Presenza norme di radioprotezione D.Lgs. 101/20",
                               Model.PresenzaNormeRadioprotezione); }
                        @{ RenderSiNoRow("Piantina", "Piantina",
                               Model.Piantina); }
                    </div>

                    <!-- ── Sala Consolle ─────────────────────── -->
                    <div class="mb-4">
                        <div class="specifiche-group-title">
                            <i class="bi bi-display me-1"></i>Sala Consolle
                        </div>
                        @{ RenderSiNoRow("SegnaleticaConsolle",
                               "Segnaletica Consolle",
                               Model.SegnaleticaConsolle); }
                        @{ RenderSiNoRow("ClassificazioneConsolle",
                               "Classificazione Consolle",
                               Model.ClassificazioneConsolle); }
                        @{ RenderSiNoRow("FunzionamentoSegnaleticaLuminosaConsolle",
                               "Funzionamento Segnaletica Luminosa Consolle",
                               Model.FunzionamentoSegnaleticaLuminosaConsolle); }
                        @{ RenderSiNoRow("SegnaleticaGravidanzaConsolle",
                               "Segnaletica donne in gravidanza",
                               Model.SegnaleticaGravidanzaConsolle); }
                        @{ RenderSiNoRow("InterLockConsolle",
                               "Inter Lock porta/fascio funzionante Sala diagnostica",
                               Model.InterLockConsolle); }
                    </div>

                    <!-- ── Sala Diagnostica ─────────────────── -->
                    <div class="mb-4">
                        <div class="specifiche-group-title">
                            <i class="bi bi-hospital me-1"></i>Sala Diagnostica
                        </div>
                        @{ RenderSiNoRow("SegnaleticaSalaDiagnostica",
                               "Segnaletica sala diagnostica",
                               Model.SegnaleticaSalaDiagnostica); }
                        @{ RenderSiNoRow("ClassificazioneSalaDiagnostica",
                               "Classificazione sala diagnostica",
                               Model.ClassificazioneSalaDiagnostica); }
                        @{ RenderSiNoRow("FunzionamentoSegnaleticaLuminosaDiagnostica",
                               "Funzionamento Segnaletica Luminosa",
                               Model.FunzionamentoSegnaleticaLuminosaDiagnostica); }
                        @{ RenderSiNoRow("SegnaleticaGravidanzaDiagnostica",
                               "Segnaletica donne in gravidanza",
                               Model.SegnaleticaGravidanzaDiagnostica); }
                    </div>

                    <!-- ── Sala Preparazione ────────────────── -->
                    <div class="mb-4">
                        <div class="specifiche-group-title">
                            <i class="bi bi-capsule me-1"></i>Sala Preparazione
                        </div>
                        @{ RenderSiNoRow("SegnaleticaSalaPreparazione",
                               "Segnaletica sala preparazione",
                               Model.SegnaleticaSalaPreparazione); }
                        @{ RenderSiNoRow("ClassificazioneSalaPreparazione",
                               "Classificazione sala preparazione",
                               Model.ClassificazioneSalaPreparazione); }
                        @{ RenderSiNoRow("FunzionamentoSegnaleticaLuminosaPreparazione",
                               "Funzionamento Segnaletica Luminosa sala preparazione",
                               Model.FunzionamentoSegnaleticaLuminosaPreparazione); }
                        @{ RenderSiNoRow("SegnaleticaGravidanzaPreparazione",
                               "Segnaletica donne in gravidanza",
                               Model.SegnaleticaGravidanzaPreparazione); }
                        @{ RenderSiNoRow("InterLockPreparazione",
                               "Inter Lock porta/fascio funzionante sala preparazione",
                               Model.InterLockPreparazione); }
                    </div>

                    <!-- ── Portatili RX / Arco a C ───────────── -->
                    <div class="mb-2">
                        <div class="specifiche-group-title">
                            <i class="bi bi-radioactive me-1"></i>Portatili RX - Arco a C
                        </div>
                        @{ RenderSiNoRow("SegnaleticaRischioRadiazioni",
                               "Segnaletica rischio presenza di radiazioni",
                               Model.SegnaleticaRischioRadiazioni); }
                        @{ RenderSiNoRow("SegnaleticaRischioGravidanza",
                               "Segnaletica rischio donne in gravidanza",
                               Model.SegnaleticaRischioGravidanza); }
                        @{ RenderSiNoRow("PresenzaNormePortatili",
                               "Presenza Norme Radioprotezione D.Lgs 101/20",
                               Model.PresenzaNormePortatili); }
                    </div>

                </div>
            </div>

        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card" style="position:sticky;top:20px;">
                <div class="card-header" style="background:var(--primary);color:white;">
                    <h3 class="card-title" style="color:white;">
                        <i class="bi bi-save me-2"></i>Salva
                    </h3>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-label" style="font-size:0.78rem;
                             color:var(--neutral-500);text-transform:uppercase">
                            Stato Sopralluogo
                        </div>
                        <select asp-for="Stato" class="form-select"
                                onchange="onStatoChange(this)">
                            <option value="Aperto">Aperto</option>
                            <option value="Chiuso">Chiuso</option>
                            <option value="InAttesaAzioni">In Attesa Azioni</option>
                        </select>
                    </div>
                    <hr class="divider" />
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle"></i>
                        @(isEdit ? "Aggiorna Sopralluogo" : "Salva Sopralluogo")
                    </button>
                    <a href="/Apparecchiature/Detail/@appId?tab=verbali"
                       class="btn btn-ghost w-100 mt-2">Annulla</a>
                </div>
            </div>
        </div>
    </div>
</form>

@* Helper Razor per righe SI/NO *@
@{
    void RenderSiNoRow(string fieldName, string label, bool? valore)
    {
        var valStr = valore == true ? "true" : valore == false ? "false" : "";
        <div class="sino-row">
            <div class="sino-label">@label</div>
            <div class="sino-btns" id="sinoGroup_@fieldName">
                <button type="button"
                        id="siBtn_@fieldName"
                        class="sino-btn sino-si @(valore == true ? "active" : "")"
                        onclick="setSiNo('@fieldName', true)">
                    <i class="bi bi-check-circle me-1"></i>Sì
                </button>
                <button type="button"
                        id="noBtn_@fieldName"
                        class="sino-btn sino-no @(valore == false ? "active" : "")"
                        onclick="setSiNo('@fieldName', false)">
                    <i class="bi bi-x-circle me-1"></i>No
                </button>
                <input type="hidden" name="@fieldName" id="hiddenSino_@fieldName"
                       value="@valStr" />
            </div>
        </div>
    }
}

@section Scripts {
<script>
function setSiNo(field, val) {
    const hiddenInput = document.getElementById('hiddenSino_' + field);
    if (hiddenInput) hiddenInput.value = val ? 'true' : 'false';

    const siBtn = document.getElementById('siBtn_' + field);
    const noBtn = document.getElementById('noBtn_' + field);

    if (siBtn) siBtn.classList.toggle('active', val === true);
    if (noBtn) noBtn.classList.toggle('active', val === false);
}

function onStatoChange(sel) {
    const div = document.getElementById('divDataChiusura');
    if (div) div.style.display = sel.value === 'Chiuso' ? 'block' : 'none';
}
</script>

<style>
/* Titolo sezione specifiche */
.specifiche-group-title {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--primary);
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1.5px solid var(--neutral-200);
}

/* Riga SI/NO */
.sino-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid var(--neutral-100);
}
.sino-row:last-child { border-bottom: none; }
.sino-label {
    flex: 1;
    font-size: 0.85rem;
    color: var(--neutral-700);
}
.sino-btns { display: flex; gap: 6px; }
.sino-btn {
    padding: 4px 14px;
    border-radius: 20px;
    border: 1.5px solid var(--neutral-200);
    background: white;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--neutral-500);
    transition: all .12s;
    white-space: nowrap;
}
.sino-si.active {
    background: #D5F5E3;
    border-color: #1E8449;
    color: #1E8449;
    font-weight: 600;
}
.sino-no.active {
    background: #FADBD8;
    border-color: #922B21;
    color: #922B21;
    font-weight: 600;
}
</style>
}
