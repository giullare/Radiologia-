@{
    Layout = "_Layout";
    ViewData["Title"] = "Accesso Negato";
}

<div class="empty-state" style="padding: 80px 24px;">
    <i class="bi bi-shield-x empty-state-icon"
       style="color: var(--danger); opacity: 0.4;"></i>
    <h2 class="empty-state-title">Accesso non autorizzato</h2>
    <p class="empty-state-text">
        Non hai i permessi necessari per visualizzare questa pagina.
        Contatta l'amministratore se ritieni che si tratti di un errore.
    </p>
    <a href="/" class="btn btn-primary">
        <i class="bi bi-house"></i>
        Torna alla Dashboard
    </a>
</div>