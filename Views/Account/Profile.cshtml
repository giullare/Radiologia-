@model RadiologiaAppNew.ViewModels.Account.ProfileViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Il mio profilo";
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-person-circle me-2 text-primary"></i>
            Il mio profilo
        </h1>
        <p class="page-subtitle">@Model.Email</p>
    </div>
</div>

<div class="row g-4">

    <div class="col-lg-4">
        <div class="card">
            <div class="card-body text-center" style="padding:32px;">
                <div style="width:80px;height:80px;border-radius:50%;
                            background:var(--primary);color:white;
                            display:flex;align-items:center;
                            justify-content:center;font-size:2rem;
                            font-weight:700;margin:0 auto 16px;">
                    @(Model.Nome.Length > 0 ? Model.Nome[0].ToString() : "")@(Model.Cognome.Length > 0 ? Model.Cognome[0].ToString() : "")
                </div>
                <h2 style="font-size:1.2rem;font-weight:700;margin-bottom:4px;">
                    @Model.Nome @Model.Cognome
                </h2>
                <div style="color:var(--neutral-500);
                            font-size:0.875rem;margin-bottom:16px;">
                    @Model.Email
                </div>
                <div class="d-flex flex-wrap gap-1 justify-content-center">
                    @foreach (var r in Model.Ruoli)
                    {
                        <span style="background:var(--primary);color:white;
                                     font-size:0.65rem;font-weight:700;
                                     padding:2px 8px;border-radius:10px;">
                            @r
                        </span>
                    }
                </div>
                @if (Model.UltimoAccesso.HasValue)
                {
                    <div style="margin-top:16px;font-size:0.775rem;
                                color:var(--neutral-400);">
                        Ultimo accesso:<br />
                        @Model.UltimoAccesso.Value
                            .ToString("dd/MM/yyyy HH:mm")
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">

        <!-- Modifica dati personali -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-person card-icon"></i>
                    Dati Personali
                </h3>
            </div>
            <div class="card-body">
                <form asp-action="Profile" asp-controller="Account"
                      method="post">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert-radiologia alert-danger mb-3">
                            <i class="bi bi-exclamation-circle alert-icon"></i>
                            <div>
                                @foreach (var e in ViewData.ModelState.Values
                                    .SelectMany(v => v.Errors))
                                {
                                    <div>@e.ErrorMessage</div>
                                }
                            </div>
                        </div>
                    }

                    <div class="row g-3">
                        <div class="col-md-5">
                            <label asp-for="Nome" class="form-label"></label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome"
                                  class="text-danger"
                                  style="font-size:0.775rem"></span>
                        </div>
                        <div class="col-md-7">
                            <label asp-for="Cognome" class="form-label"></label>
                            <input asp-for="Cognome" class="form-control" />
                            <span asp-validation-for="Cognome"
                                  class="text-danger"
                                  style="font-size:0.775rem"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input value="@Model.Email"
                                   class="form-control" disabled
                                   style="background:var(--neutral-100);" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label"></label>
                            <input asp-for="Telefono" class="form-control"
                                   placeholder="Interno o mobile" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i>
                            Salva Modifiche
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Cambia password -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-lock card-icon"></i>
                    Cambia Password
                </h3>
            </div>
            <div class="card-body">
                <form asp-action="CambiaPassword"
                      asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Password Attuale</label>
                            <input type="password"
                                   name="PasswordAttuale"
                                   class="form-control"
                                   placeholder="••••••••" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Nuova Password</label>
                            <input type="password"
                                   name="NuovaPassword"
                                   class="form-control"
                                   placeholder="Min. 8 caratteri" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Conferma Password</label>
                            <input type="password"
                                   name="ConfermaPassword"
                                   class="form-control"
                                   placeholder="Ripeti password" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-outline">
                            <i class="bi bi-lock"></i>
                            Cambia Password
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>