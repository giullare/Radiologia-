@model RadiologiaAppNew.ViewModels.Account.CambiaPasswordViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Cambia Password";
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-lock me-2 text-primary"></i>
            Cambia Password
        </h1>
    </div>
    <div class="page-actions">
        <a href="/Account/Profile" class="btn btn-ghost">
            <i class="bi bi-arrow-left"></i> Torna al profilo
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-body" style="padding:32px;">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-radiologia alert-danger mb-4">
                        <i class="bi bi-exclamation-circle alert-icon"></i>
                        <div>
                            @foreach (var e in ViewData.ModelState.Values
                                .SelectMany(v => v.Errors))
                            {
                                <div>@e.ErrorMessage</div>
                            }
                        </div>
                    </div>
                }

                <form asp-action="CambiaPassword"
                      asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="PasswordAttuale"
                               class="form-label"></label>
                        <input asp-for="PasswordAttuale"
                               type="password" class="form-control"
                               placeholder="Password attuale" />
                        <span asp-validation-for="PasswordAttuale"
                              class="text-danger"
                              style="font-size:0.775rem"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NuovaPassword"
                               class="form-label"></label>
                        <input asp-for="NuovaPassword"
                               type="password" class="form-control"
                               placeholder="Min. 8 caratteri" />
                        <span asp-validation-for="NuovaPassword"
                              class="text-danger"
                              style="font-size:0.775rem"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ConfermaPassword"
                               class="form-label"></label>
                        <input asp-for="ConfermaPassword"
                               type="password" class="form-control"
                               placeholder="Ripeti nuova password" />
                        <span asp-validation-for="ConfermaPassword"
                              class="text-danger"
                              style="font-size:0.775rem"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-lock"></i>
                        Cambia Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>