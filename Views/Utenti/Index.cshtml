@model List<RadiologiaAppNew.Controllers.UtenteRowVm>
@using RadiologiaAppNew.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Gestione Utenti";
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-people me-2 text-primary"></i>
            Gestione Utenti
        </h1>
        <p class="page-subtitle">
            @Model.Count utenti totali ·
            @Model.Count(u => u.Attivo) attivi ·
            @Model.Count(u => !u.Attivo) disabilitati
        </p>
    </div>
    <div class="page-actions">
        <a href="/Utenti/Create" class="btn btn-primary">
            <i class="bi bi-person-plus"></i>
            Nuovo Utente
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="bi bi-people empty-state-icon"></i>
        <div class="empty-state-title">Nessun utente</div>
        <p class="empty-state-text">Crea il primo account utente.</p>
        <a href="/Utenti/Create" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Nuovo Utente
        </a>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table-radiologia w-100">
                <thead>
                    <tr>
                        <th>Utente</th>
                        <th>Ruoli</th>
                        <th>Moduli Abilitati</th>
                        <th>Ultimo Accesso</th>
                        <th>Stato</th>
                        <th style="width:120px">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <!-- Utente -->
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:36px;height:36px;border-radius:50%;
                                                background:var(--primary);color:white;
                                                display:flex;align-items:center;
                                                justify-content:center;
                                                font-weight:600;font-size:0.8rem;
                                                flex-shrink:0;">
                                        @((u.Nome.Length > 0 ? u.Nome[0].ToString() : "") +
                                          (u.Cognome.Length > 0 ? u.Cognome[0].ToString() : ""))
                                    </div>
                                    <div>
                                        <div class="fw-600" style="font-size:0.875rem">
                                            @u.Cognome @u.Nome
                                        </div>
                                        <div style="font-size:0.775rem;color:var(--neutral-500)">
                                            @u.Email
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <!-- Ruoli -->
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var r in u.Ruoli.Take(3))
                                    {
                                        var coloreRuolo = r switch
                                        {
                                            "ADMIN_ORG"  => "danger",
                                            "EFM"        => "primary",
                                            "EDR"        => "success",
                                            "RIR"        => "info",
                                            "SFM"        => "primary",
                                            "MA"  or "ES" or "MR" => "secondary",
                                            "RQ"         => "warning",
                                            _            => "secondary"
                                        };
                                        <span class="badge bg-@coloreRuolo bg-opacity-15
                                                     text-@coloreRuolo fw-normal"
                                              style="font-size:0.72rem">
                                            @r
                                        </span>
                                    }
                                    @if (u.Ruoli.Count > 3)
                                    {
                                        <span class="badge bg-secondary bg-opacity-15
                                                     text-secondary fw-normal"
                                              style="font-size:0.72rem">
                                            +@(u.Ruoli.Count - 3)
                                        </span>
                                    }
                                </div>
                            </td>

                            <!-- Moduli abilitati -->
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var mod in u.ModuliEffettivi)
                                    {
                                        var icona = mod switch
                                        {
                                            ModuliHelper.MOD1 => "bi-radioactive",
                                            ModuliHelper.MOD2 => "bi-magnet",
                                            ModuliHelper.MOD3 => "bi-activity",
                                            ModuliHelper.MOD4 => "bi-heart-pulse",
                                            _ => "bi-grid"
                                        };
                                        <span class="badge bg-primary bg-opacity-10
                                                     text-primary fw-normal
                                                     d-flex align-items-center gap-1"
                                              style="font-size:0.72rem"
                                              title="@(ModuliHelper.NomiModuli.ContainsKey(mod)
                                                       ? ModuliHelper.NomiModuli[mod] : mod)">
                                            <i class="bi @icona"></i> @mod
                                        </span>
                                    }
                                    @if (!u.ModuliEffettivi.Any())
                                    {
                                        <span style="font-size:0.775rem;
                                                     color:var(--neutral-400)">
                                            —
                                        </span>
                                    }
                                </div>
                            </td>

                            <!-- Ultimo accesso -->
                            <td>
                                <span style="font-size:0.825rem;color:var(--neutral-600)">
                                    @if (u.UltimoAccesso.HasValue)
                                    {
                                        @u.UltimoAccesso.Value.ToString("dd/MM/yyyy HH:mm")
                                    }
                                    else
                                    {
                                        <span style="color:var(--neutral-400)">Mai</span>
                                    }
                                </span>
                            </td>

                            <!-- Stato -->
                            <td>
                                @if (u.Attivo)
                                {
                                    <span class="badge-compliance badge-ok">
                                        <i class="bi bi-check-circle"></i> Attivo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-compliance badge-danger">
                                        <i class="bi bi-x-circle"></i> Disabilitato
                                    </span>
                                }
                            </td>

                            <!-- Azioni -->
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Utenti/Detail/@u.Id"
                                       class="btn btn-ghost btn-sm"
                                       title="Dettaglio">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="/Utenti/Edit/@u.Id"
                                       class="btn btn-ghost btn-sm"
                                       title="Modifica">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleAttivo"
                                          asp-route-id="@u.Id"
                                          method="post"
                                          style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-ghost btn-sm"
                                                title="@(u.Attivo ? "Disabilita" : "Riabilita")"
                                                data-confirm="@(u.Attivo
                                                    ? $"Disabilitare l'account di {u.Cognome} {u.Nome}?"
                                                    : $"Riabilitare l'account di {u.Cognome} {u.Nome}?")">
                                            <i class="bi @(u.Attivo
                                                ? "bi-person-slash text-warning"
                                                : "bi-person-check text-success")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Delete"
                                          asp-route-id="@u.Id"
                                          method="post"
                                          style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-ghost btn-sm"
                                                title="Elimina"
                                                data-confirm="Eliminare definitivamente @u.Cognome @u.Nome? L'operazione non è reversibile.">
                                            <i class="bi bi-trash text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
