@model RadiologiaAppNew.Controllers.Lu177StatisticheVm
@{
    Layout = "_Layout";
    ViewData["Title"] = "Statistiche Cliniche Lu177";
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-bar-chart me-2 text-primary"></i>
            Statistiche Cliniche Lu177
        </h1>
        <p class="page-subtitle">Dati aggregati anonimizzati</p>
    </div>
    <div class="page-actions">
        <a href="/Lu177" class="btn btn-ghost">
            <i class="bi bi-arrow-left"></i> Pazienti
        </a>
    </div>
</div>

<div class="kpi-grid mb-4">
    <div class="kpi-card kpi-primary">
        <div class="kpi-content">
            <div class="kpi-number">@Model.TotalePazienti</div>
            <div class="kpi-label">Pazienti Totali</div>
        </div>
        <i class="bi bi-people kpi-icon"></i>
    </div>
    <div class="kpi-card kpi-success">
        <div class="kpi-content">
            <div class="kpi-number">@Model.InTrattamento</div>
            <div class="kpi-label">In Trattamento</div>
        </div>
        <i class="bi bi-person-heart kpi-icon"></i>
    </div>
    <div class="kpi-card kpi-secondary">
        <div class="kpi-content">
            <div class="kpi-number">@Model.TotaleCicli</div>
            <div class="kpi-label">Cicli Totali</div>
        </div>
        <i class="bi bi-arrow-repeat kpi-icon"></i>
    </div>
    <div class="kpi-card" style="border-left-color:var(--accent)">
        <div class="kpi-content">
            <div class="kpi-number">@Model.MediaCicliPerPaziente</div>
            <div class="kpi-label">Media Cicli/Paziente</div>
        </div>
        <i class="bi bi-calculator kpi-icon"></i>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-pie-chart card-icon"></i>
                    Distribuzione per Indicazione
                </h3>
            </div>
            <div class="card-body d-flex
                         align-items-center justify-content-center">
                @if (Model.TotalePazienti == 0)
                {
                    <div class="empty-state">
                        <i class="bi bi-bar-chart empty-state-icon"></i>
                        <div class="empty-state-title">
                            Nessun dato disponibile
                        </div>
                    </div>
                }
                else
                {
                    <canvas id="chartIndicazione"
                            style="max-height:240px;"></canvas>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-bar-chart card-icon"></i>
                    Tossicità Ematologica (CTCAE)
                </h3>
            </div>
            <div class="card-body">
                @if (!Model.DistribuzioneTossicita.Values.Any(v => v > 0))
                {
                    <div class="empty-state" style="padding:30px;">
                        <i class="bi bi-droplet empty-state-icon"></i>
                        <div class="empty-state-title">
                            Nessun dato ematologico
                        </div>
                    </div>
                }
                else
                {
                    <canvas id="chartTossicita"
                            style="height:220px;"></canvas>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
@if (Model.TotalePazienti > 0)
{
    <text>
    const ctxInd = document.getElementById('chartIndicazione');
    if (ctxInd) {
        new Chart(ctxInd, {
            type: 'doughnut',
            data: {
                labels: ['PSMA Lu177', 'DOTATATE Lu177', 'Altro'],
                datasets: [{
                    data: [
                        @Model.CountPsma,
                        @Model.CountDotatate,
                        @(Model.TotalePazienti - Model.CountPsma - Model.CountDotatate)
                    ],
                    backgroundColor: ['#1B4F72','#148F77','#E67E22'],
                    borderWidth: 3,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                cutout: '60%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { usePointStyle: true, font: { size: 11 } }
                    }
                }
            }
        });
    }
    </text>
}
@if (Model.DistribuzioneTossicita.Values.Any(v => v > 0))
{
    <text>
    const ctxToss = document.getElementById('chartTossicita');
    if (ctxToss) {
        new Chart(ctxToss, {
            type: 'bar',
            data: {
                labels: ['G0','G1','G2','G3','G4'],
                datasets: [{
                    label: 'Pazienti',
                    data: [
                        @Model.DistribuzioneTossicita.GetValueOrDefault("G0"),
                        @Model.DistribuzioneTossicita.GetValueOrDefault("G1"),
                        @Model.DistribuzioneTossicita.GetValueOrDefault("G2"),
                        @Model.DistribuzioneTossicita.GetValueOrDefault("G3"),
                        @Model.DistribuzioneTossicita.GetValueOrDefault("G4")
                    ],
                    backgroundColor: [
                        '#27AE60','#2ECC71','#F39C12','#E67E22','#C0392B'
                    ],
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 } },
                    x: { grid: { display: false } }
                },
                plugins: { legend: { display: false } }
            }
        });
    }
    </text>
}
</script>
}