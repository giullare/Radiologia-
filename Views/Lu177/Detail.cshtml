@model RadiologiaAppNew.Models.PazienteLu177
@{
    Layout = "_Layout";
    ViewData["Title"] = $"{Model.Cognome} {Model.Nome}";
}

<div class="page-header">
    <div>
        <div class="d-flex align-items-center gap-2 mb-1">
            <code style="font-size:0.8rem;background:var(--neutral-100);
                         padding:2px 8px;border-radius:4px;">
                @Model.CodicePaziente
            </code>
            @{
                var (pClass, pLabel) = Model.StatoPaziente switch
                {
                    RadiologiaAppNew.Enums.StatoPaziente.InTrattamento =>
                        ("stato-attiva", "In Trattamento"),
                    RadiologiaAppNew.Enums.StatoPaziente.Concluso =>
                        ("stato-cessata", "Concluso"),
                    RadiologiaAppNew.Enums.StatoPaziente.Deceduto =>
                        ("stato-cessata", "Deceduto"),
                    _ => ("stato-in-manutenzione", "Perso FU")
                };
            }
            <span class="stato-badge @pClass">@pLabel</span>
        </div>
        <h1 class="page-title">
            @Model.Cognome @Model.Nome
        </h1>
        <p class="page-subtitle">
            @Model.Indicazione.Replace("_LU177","") ·
            Nato il @Model.DataNascita.ToString("dd/MM/yyyy") ·
            @(DateTime.Today.Year - Model.DataNascita.Year) anni
        </p>
    </div>
    <div class="page-actions">
        @if (User.IsInRole("ADMIN_ORG") || User.IsInRole("EFM") ||
             User.IsInRole("EDR"))
        {
            <a href="/Lu177/NuovoCiclo/@Model.Id"
               class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Nuovo Ciclo
            </a>
            <a href="/Lu177/NuovoEmatologico/@Model.Id"
               class="btn btn-outline">
                <i class="bi bi-droplet"></i>
                Dato Ematologico
            </a>
        }
    </div>
</div>

<div class="row g-4">

    <!-- Colonna sinistra -->
    <div class="col-lg-8">

        <!-- Cicli di trattamento -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-arrow-repeat card-icon"></i>
                    Cicli di Trattamento
                    (@Model.CicliTrattamento.Count
                    @if (Model.NCicliPianificati.HasValue)
                    {
                        <span>/ @Model.NCicliPianificati pianificati</span>
                    })
                </h3>
                <a href="/Lu177/NuovoCiclo/@Model.Id"
                   class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-circle"></i>
                    Aggiungi Ciclo
                </a>
            </div>
            @if (!Model.CicliTrattamento.Any())
            {
                <div class="empty-state" style="padding:30px;">
                    <i class="bi bi-arrow-repeat empty-state-icon"></i>
                    <div class="empty-state-title">Nessun ciclo registrato</div>
                    <a href="/Lu177/NuovoCiclo/@Model.Id"
                       class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-circle"></i>
                        Primo Ciclo
                    </a>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table class="table-radiologia w-100">
                        <thead>
                            <tr>
                                <th>Ciclo</th>
                                <th>Data</th>
                                <th>Attività Somm.</th>
                                <th>Attività Effettiva</th>
                                <th>Lotto</th>
                                <th>Peso</th>
                                <th>Esito</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.CicliTrattamento
                                .OrderBy(c => c.NumeroCiclo))
                            {
                                <tr>
                                    <td>
                                        <span class="fw-700"
                                              style="font-size:1.1rem;
                                                     color:var(--primary);">
                                            #@c.NumeroCiclo
                                        </span>
                                    </td>
                                    <td>
                                        @c.DataSomministrazione
                                            .ToString("dd/MM/yyyy")
                                        <div style="font-size:0.75rem;
                                                    color:var(--neutral-500);">
                                            @c.OraSomministrazione.ToString(@"hh\:mm")
                                        </div>
                                    </td>
                                    <td>
                                        <span class="fw-600">
                                            @c.AttivitaSomministrataGbq GBq
                                        </span>
                                    </td>
                                    <td>
                                        <span class="fw-600"
                                              style="color:var(--secondary);">
                                            @((c.AttivitaSomministrataGbq -
                                               c.AttivitaResiduaSiringaGbq)
                                               .ToString("F3")) GBq
                                        </span>
                                    </td>
                                    <td>
                                        <span style="font-size:0.8rem;">
                                            @c.LottoRadiofarmaco
                                        </span>
                                        <div style="font-size:0.75rem;
                                                    color:var(--neutral-500);">
                                            @c.FornitoreRadiofarmaco
                                        </div>
                                    </td>
                                    <td>@c.PesoPazienteCicloKg kg</td>
                                    <td>
                                        @{
                                            var cClass = c.EsitoCiclo switch
                                            {
                                                "Completato" => "badge-ok",
                                                "Ridotto"    => "badge-warning",
                                                "Sospeso"    => "badge-warning",
                                                "Interrotto" => "badge-danger",
                                                _ => "badge-missing"
                                            };
                                        }
                                        <span class="badge-compliance @cClass"
                                              style="font-size:0.75rem;">
                                            @c.EsitoCiclo
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Dati ematologici -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-droplet card-icon"></i>
                    Follow-Up Ematologico
                    (@Model.DatiEmatologici.Count)
                </h3>
                <a href="/Lu177/NuovoEmatologico/@Model.Id"
                   class="btn btn-ghost btn-sm">
                    <i class="bi bi-plus"></i>
                    Aggiungi
                </a>
            </div>
            @if (!Model.DatiEmatologici.Any())
            {
                <div class="empty-state" style="padding:24px;">
                    <i class="bi bi-droplet empty-state-icon"></i>
                    <div class="empty-state-title">
                        Nessun dato ematologico
                    </div>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table class="table-radiologia w-100">
                        <thead>
                            <tr>
                                <th>Data</th>
                                <th>Timing</th>
                                <th>WBC</th>
                                <th>Hgb</th>
                                <th>PLT</th>
                                <th>eGFR</th>
                                @if (Model.Indicazione == "PSMA_LU177")
                                {
                                    <th>PSA</th>
                                }
                                <th>Tossicità</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in Model.DatiEmatologici
                                .OrderByDescending(d => d.DataPrelievo))
                            {
                                <tr>
                                    <td>@e.DataPrelievo.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span style="font-size:0.8rem;">
                                            @e.Timing
                                        </span>
                                    </td>
                                    <td>@(e.WbcX10_9L?.ToString("F1") ?? "—")</td>
                                    <td>@(e.HgbGdl?.ToString("F1") ?? "—")</td>
                                    <td>@(e.PltX10_9L?.ToString("F0") ?? "—")</td>
                                    <td>@(e.EgfrMlMin?.ToString("F0") ?? "—")</td>
                                    @if (Model.Indicazione == "PSMA_LU177")
                                    {
                                        <td>@(e.PsaNgMl?.ToString("F1") ?? "—")</td>
                                    }
                                    <td>
                                        @if (!string.IsNullOrEmpty(
                                            e.TossicitaEmatologica))
                                        {
                                            var tClass = e.TossicitaEmatologica switch
                                            {
                                                "G0" => "badge-ok",
                                                "G1" => "badge-ok",
                                                "G2" => "badge-warning",
                                                "G3" => "badge-danger",
                                                "G4" => "badge-danger",
                                                _    => "badge-missing"
                                            };
                                            <span class="badge-compliance @tClass"
                                                  style="font-size:0.75rem;">
                                                @e.TossicitaEmatologica
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="color:var(--neutral-400);">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>

    <!-- Colonna destra -->
    <div class="col-lg-4">

        <!-- Anagrafica -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-person card-icon"></i>
                    Anagrafica
                </h3>
            </div>
            <div class="card-body">
                <div class="mb-2">
                    <div class="form-label">Medico Inviante</div>
                    <div class="fw-600" style="font-size:0.9rem;">
                        @Model.MedicoInviante
                    </div>
                    @if (!string.IsNullOrEmpty(Model.RepartoInviante))
                    {
                        <div style="font-size:0.8rem;
                                    color:var(--neutral-500);">
                            @Model.RepartoInviante
                        </div>
                    }
                </div>
                <div class="mb-2">
                    <div class="form-label">Diagnosi</div>
                    <div style="font-size:0.85rem;">
                        @Model.DiagnosiPrincipale
                    </div>
                </div>
                @if (Model.PesoKg.HasValue)
                {
                    <div class="mb-2">
                        <div class="form-label">Peso / Altezza</div>
                        <div class="fw-600" style="font-size:0.9rem;">
                            @Model.PesoKg kg
                            @if (Model.AltezzaCm.HasValue)
                            {
                                <span> / @Model.AltezzaCm cm</span>
                            }
                        </div>
                    </div>
                }
                @if (Model.EgfrMlMin.HasValue)
                {
                    <div class="mb-2">
                        <div class="form-label">eGFR basale</div>
                        <div class="fw-600"
                             style="color:@(Model.EgfrMlMin < 30
                                 ? "var(--danger)"
                                 : Model.EgfrMlMin < 60
                                     ? "var(--warning)"
                                     : "var(--success)");">
                            @Model.EgfrMlMin mL/min/1.73m²
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Piano terapeutico -->
        @if (!string.IsNullOrEmpty(Model.ProtocolloTerapeutico))
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="bi bi-clipboard-pulse card-icon"></i>
                        Piano Terapeutico
                    </h3>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <div class="form-label">Protocollo</div>
                        <div class="fw-600">@Model.ProtocolloTerapeutico</div>
                    </div>
                    @if (Model.NCicliPianificati.HasValue)
                    {
                        <div class="mb-2">
                            <div class="form-label">Cicli Pianificati</div>
                            <div class="fw-600">
                                @Model.CicliTrattamento.Count
                                / @Model.NCicliPianificati
                            </div>
                            <div style="background:var(--neutral-200);
                                        border-radius:4px;height:6px;
                                        margin-top:6px;overflow:hidden;">
                                <div style="background:var(--primary);
                                            height:100%;border-radius:4px;
                                            width:@(Math.Min(100,
                                                Model.CicliTrattamento.Count * 100 /
                                                Math.Max(1, Model.NCicliPianificati.Value)))%;">
                                </div>
                            </div>
                        </div>
                    }
                    @if (Model.AttivitaPerCicloGbq.HasValue)
                    {
                        <div>
                            <div class="form-label">Attività per Ciclo</div>
                            <div class="fw-600">
                                @Model.AttivitaPerCicloGbq GBq
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Azioni -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-lightning card-icon"></i>
                    Azioni
                </h3>
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <a href="/Lu177/NuovoCiclo/@Model.Id"
                   class="btn btn-primary w-100">
                    <i class="bi bi-plus-circle"></i>
                    Nuovo Ciclo Trattamento
                </a>
                <a href="/Lu177/NuovoEmatologico/@Model.Id"
                   class="btn btn-outline w-100">
                    <i class="bi bi-droplet"></i>
                    Nuovo Dato Ematologico
                </a>
                <a href="/Lu177/Statistiche"
                   class="btn btn-ghost w-100">
                    <i class="bi bi-bar-chart"></i>
                    Statistiche Cliniche
                </a>
            </div>
        </div>

    </div>
</div>