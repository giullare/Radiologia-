<!-- ═══ TAB: PROTOCOLLI ═════════════════════════════════════════════ -->
<div class="tab-panel @(tabAttivo=="protocolli"?"active":"")"
     id="tab-protocolli">

    <!-- Form in cima -->
    <div class="card mb-4"
         style="border:2px solid var(--primary);">
        <div class="card-header"
             style="background:var(--primary);color:white;">
            <h3 class="card-title" style="color:white;">
                <i class="bi bi-plus-circle me-2"></i>
                Nuovo Protocollo di Verifica
            </h3>
        </div>
        <div class="card-body">
            <form asp-action="NuovoProtocollo"
                  asp-controller="Configurazione" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="tab" value="protocolli" />
                <div class="row g-2">
                    <div class="col-md-2">
                        <input type="text" name="codice"
                               class="form-control"
                               placeholder="Codice *" required />
                    </div>
                    <div class="col-md-4">
                        <input type="text" name="descrizione"
                               class="form-control"
                               placeholder="Descrizione *" required />
                    </div>
                    <div class="col-md-3">
                        <select name="tipo" class="form-select"
                                required>
                            @foreach (var t in Enum.GetValues<RadiologiaAppNew.Enums.TipoProtocollo>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-1">
                        <input type="number" name="periodicitaMesi"
                               class="form-control"
                               placeholder="Mesi" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit"
                                class="btn btn-primary w-100">
                            <i class="bi bi-plus-circle"></i>
                            Aggiungi
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Lista protocolli -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="bi bi-file-text card-icon"></i>
                Protocolli (@Model.Protocolli.Count)
            </h3>
        </div>
        <div style="overflow-x:auto;">
            <table class="table-radiologia w-100">
                <thead>
                    <tr>
                        <th>Codice</th>
                        <th>Descrizione</th>
                        <th>Tipo</th>
                        <th>Periodicità</th>
                        <th>Stato</th>
                        <th style="width:100px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Protocolli)
                    {
                        <tr style="opacity:@(p.Attivo?"1":"0.5");">
