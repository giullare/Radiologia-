                            <td style="font-size:0.85rem;">
                                @p.Descrizione
                            </td>
                            <td>
                                <span style="font-size:0.8rem;
                                             color:var(--primary);
                                             font-weight:600;">
                                    @p.Tipo
                                </span>
                            </td>
                            <td style="font-size:0.85rem;">
                                @(p.PeriodicitaMesi.HasValue
                                    ? $"{p.PeriodicitaMesi} mesi"
                                    : "—")
