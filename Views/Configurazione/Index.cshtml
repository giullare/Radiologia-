                                <span class="badge-compliance
                                    @(p.Attivo?"badge-ok":"badge-missing")">
                                    @(p.Attivo ? "Attivo" : "Inattivo")
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <form asp-action="ToggleProtocollo"
                                          asp-controller="Configurazione"
                                          method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id"
                                               value="@p.Id" />
                                        <input type="hidden" name="tab"
                                               value="protocolli" />
                                        <button type="submit"
                                                class="btn btn-ghost btn-icon btn-sm"
                                                title="@(p.Attivo?"Disattiva":"Attiva")">
                                            <i class="bi @(p.Attivo
                                                ? "bi-toggle-on text-success"
                                                : "bi-toggle-off")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="EliminaProtocollo"
                                          asp-controller="Configurazione"
                                          method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id"
                                               value="@p.Id" />
                                        <input type="hidden" name="tab"
                                               value="protocolli" />
                                        <button type="submit"
                                                class="btn btn-ghost btn-icon btn-sm"
                                                data-confirm="Eliminare definitivamente il protocollo «@p.Codice»? L'operazione non è reversibile."
                                                title="Elimina protocollo">
                                            <i class="bi bi-trash3"
                                               style="color:var(--danger);">
                                            </i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ─── TAB ─────────────────────────────────────────────────────────
function switchTabConf(name, btn) {
    document.querySelectorAll('.tab-btn')
        .forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel')
        .forEach(p => p.classList.remove('active'));
    document.querySelector(`#tab-${name}`)
        ?.classList.add('active');
    (btn || event?.currentTarget)?.classList.add('active');
    history.replaceState(null, '', `?tab=${name}`);
}

// ─── COLLAPSE SINGOLO ────────────────────────────────────────────
function toggleCollapse(id) {
    const body = document.getElementById(id);
    const icon = document.getElementById(`icon-${id}`);
    if (!body) return;
    const isVisible = body.style.display !== 'none';
    body.style.display = isVisible ? 'none' : 'block';
    if (icon) icon.style.transform =
        isVisible ? '' : 'rotate(180deg)';
}

// ─── COLLAPSE / EXPAND TUTTI ─────────────────────────────────────
function expandAll(prefix) {
    document.querySelectorAll(`[id^="${prefix}-"]`).forEach(el => {
        if (!el.id.includes('icon')) {
            el.style.display = 'block';
        }
    });
    document.querySelectorAll(`[id^="icon-${prefix}-"]`).forEach(el => {
        el.style.transform = 'rotate(180deg)';
    });
}

function collapseAll(prefix) {
    document.querySelectorAll(`[id^="${prefix}-"]`).forEach(el => {
        if (!el.id.includes('icon')) {
            el.style.display = 'none';
        }
    });
    document.querySelectorAll(`[id^="icon-${prefix}-"]`).forEach(el => {
        el.style.transform = '';
    });
}
</script>
}