@{
    Layout = "_Layout";
    ViewData["Title"] = "Errore";
}

<div class="empty-state" style="padding:80px 24px;">
    <i class="bi bi-exclamation-triangle-fill empty-state-icon"
       style="color:var(--danger);opacity:0.4;font-size:4rem;"></i>
    <h2 class="empty-state-title">Si è verificato un errore</h2>
    <p class="empty-state-text">
        Si è verificato un problema imprevisto durante l'elaborazione
        della richiesta. Il problema è stato registrato automaticamente.
        <br />
        Se il problema persiste, contatta l'amministratore di sistema.
    </p>
    <div class="d-flex gap-3 justify-content-center">
        <a href="/" class="btn btn-primary">
            <i class="bi bi-house"></i>
            Torna alla Dashboard
        </a>
        <button onclick="history.back()" class="btn btn-ghost">
            <i class="bi bi-arrow-left"></i>
            Torna indietro
        </button>
    </div>
    <div style="margin-top:32px;font-size:0.775rem;
                color:var(--neutral-400);">
        RadiologiaApp — Fisica Sanitaria e Radioprotezione
    </div>
</div>