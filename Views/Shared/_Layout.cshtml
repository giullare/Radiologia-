<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RadiologiaApp</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />
    <!-- CSS custom -->
    <link rel="stylesheet" href="~/css/radiologia.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- ═══ APP WRAPPER ═══════════════════════════════════════════ -->
    <div class="app-wrapper" id="appWrapper">

        <!-- ═══ SIDEBAR ══════════════════════════════════════════ -->
        <aside class="sidebar" id="sidebar">

            <!-- Brand -->
            <a class="sidebar-brand" href="/">
                <div class="sidebar-brand-icon">
                    <i class="bi bi-radioactive"></i>
                </div>
                <div class="sidebar-brand-text">
                    <span class="app-name">RadiologiaApp</span>
                    <span class="app-subtitle">Fisica Sanitaria</span>
                </div>
            </a>

            <!-- Nav -->
            <nav class="sidebar-nav">

                <!-- Dashboard -->
                <div class="nav-section-title">Generale</div>

                <div class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       href="/Home/Index">
                        <i class="bi bi-speedometer2 nav-icon"></i>
                        <span class="nav-label">Dashboard</span>
                    </a>
                </div>

                <!-- Modulo 1 -->
                <div class="nav-section-title">Modulo 1 — Radiologia</div>

                <div class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Apparecchiature" ? "open" : "")">
                    <button class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Apparecchiature" ? "active" : "")"
                            onclick="toggleSubmenu(this)">
                        <i class="bi bi-hdd-rack nav-icon"></i>
                        <span class="nav-label">Apparecchiature</span>
                        <i class="bi bi-chevron-right nav-arrow"></i>
                    </button>
                    <div class="nav-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "Apparecchiature" ? "open" : "")">
                        <div class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "Apparecchiature" ? "active" : "")"
                               href="/Apparecchiature">
                                <i class="bi bi-list-ul nav-icon"></i>
                                <span class="nav-label">Catalogo</span>
                            </a>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
                               href="/Apparecchiature/Create">
                                <i class="bi bi-plus-circle nav-icon"></i>
                                <span class="nav-label">Nuova Apparecchiatura</span>
                            </a>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link" href="/Apparecchiature?stato=Cessata">
                                <i class="bi bi-archive nav-icon"></i>
                                <span class="nav-label">Cessate</span>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Verifiche" ? "open" : "")">
                    <button class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Verifiche" ? "active" : "")"
                            onclick="toggleSubmenu(this)">
                        <i class="bi bi-clipboard2-check nav-icon"></i>
                        <span class="nav-label">Verifiche CQ</span>
                        <i class="bi bi-chevron-right nav-arrow"></i>
                    </button>
                    <div class="nav-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "Verifiche" ? "open" : "")">
                        <div class="nav-item">
                            <a class="nav-link" href="/Verifiche">
                                <i class="bi bi-list-check nav-icon"></i>
                                <span class="nav-label">Tutte le Verifiche</span>
                            </a>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link" href="/Verifiche?tipo=Accettazione">
                                <i class="bi bi-check2-circle nav-icon"></i>
                                <span class="nav-label">Accettazioni</span>
                            </a>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link" href="/Verifiche?tipo=Ldr">
                                <i class="bi bi-graph-up nav-icon"></i>
                                <span class="nav-label">LDR</span>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Adempimenti" ? "open" : "")">
                    <button class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Adempimenti" ? "active" : "")"
                            onclick="toggleSubmenu(this)">
                        <i class="bi bi-file-earmark-text nav-icon"></i>
                        <span class="nav-label">Adempimenti EDR</span>
                        <i class="bi bi-chevron-right nav-arrow"></i>
                    </button>
                    <div class="nav-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "Adempimenti" ? "open" : "")">
                        <div class="nav-item">
                            <a class="nav-link" href="/Adempimenti/NotifichePratica">
                                <i class="bi bi-send nav-icon"></i>
                                <span class="nav-label">Notifiche di Pratica</span>
                            </a>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link" href="/Adempimenti/NullaOsta">
                                <i class="bi bi-shield-check nav-icon"></i>
                                <span class="nav-label">Nulla Osta</span>
                            </a>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link" href="/Adempimenti/Verbali">
                                <i class="bi bi-journal-text nav-icon"></i>
                                <span class="nav-label">Verbali Sopralluogo</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Modulo 2 -->
                <div class="nav-section-title">Modulo 2 — RM</div>

                <div class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "RisonanzaMagnetica" ? "active" : "")"
                       href="/RisonanzaMagnetica">
                        <i class="bi bi-magnet nav-icon"></i>
                        <span class="nav-label">Risonanza Magnetica</span>
                    </a>
                </div>

                <!-- Modulo 3 -->
                <div class="nav-section-title">Modulo 3 — Med. Nucleare</div>

                <div class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MedicinaNucleare" ? "active" : "")"
                       href="/MedicinaNucleare">
                        <i class="bi bi-radioactive nav-icon"></i>
                        <span class="nav-label">Registri MN</span>
                    </a>
                </div>

                <!-- Modulo 4 -->
                <div class="nav-section-title">Modulo 4 — Lu177</div>

                <div class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Lu177" ? "open" : "")">
                    <button class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Lu177" ? "active" : "")"
                            onclick="toggleSubmenu(this)">
                        <i class="bi bi-person-heart nav-icon"></i>
                        <span class="nav-label">Terapia Lu177</span>
                        <i class="bi bi-chevron-right nav-arrow"></i>
                    </button>
                    <div class="nav-submenu @(ViewContext.RouteData.Values["controller"]?.ToString() == "Lu177" ? "open" : "")">
                        <div class="nav-item">
                            <a class="nav-link" href="/Lu177">
                                <i class="bi bi-people nav-icon"></i>
                                <span class="nav-label">Pazienti</span>
                            </a>
                        </div>
                        <div class="nav-item">
                            <a class="nav-link" href="/Lu177/Statistiche">
                                <i class="bi bi-bar-chart nav-icon"></i>
                                <span class="nav-label">Statistiche Cliniche</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Admin -->
                @if (User.IsInRole("ADMIN_ORG"))
                {
                    <div class="nav-section-title">Amministrazione</div>

                    <div class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Utenti" ? "active" : "")"
                           href="/Utenti">
                            <i class="bi bi-people nav-icon"></i>
                            <span class="nav-label">Gestione Utenti</span>
                        </a>
                    </div>

                    <div class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Configurazione" ? "active" : "")"
                           href="/Configurazione">
                            <i class="bi bi-gear nav-icon"></i>
                            <span class="nav-label">Configurazione</span>
                        </a>
                    </div>
                }

            </nav>

            <!-- Footer sidebar -->
            <div class="sidebar-footer">
                <div class="sidebar-footer-text">
                    RadiologiaApp v1.0<br />
                    D.Lgs. 101/20 — DM 01/21
                </div>
            </div>

        </aside>
        <!-- fine sidebar -->

        <!-- ═══ HEADER ════════════════════════════════════════════ -->
        <header class="app-header">

            <!-- Toggle sidebar -->
            <button class="header-toggle" id="sidebarToggle" title="Espandi/Comprimi menu">
                <i class="bi bi-list"></i>
            </button>

            <!-- Breadcrumb -->
            <nav class="header-breadcrumb">
                <a href="/">
                    <i class="bi bi-house"></i>
                </a>
                @if (ViewData["BreadcrumbParent"] != null)
                {
                    <span class="bc-separator">/</span>
                    @if (ViewData["BreadcrumbParentUrl"] != null)
                    {
                        <a href="@ViewData["BreadcrumbParentUrl"]">@ViewData["BreadcrumbParent"]</a>
                    }
                    else
                    {
                        <span>@ViewData["BreadcrumbParent"]</span>
                    }
                }
                @if (ViewData["Title"] != null)
                {
                    <span class="bc-separator">/</span>
                    <span class="bc-current">@ViewData["Title"]</span>
                }
            </nav>

            <!-- Azioni header -->
            <div class="header-actions">

                <!-- Notifiche -->
                <a class="header-btn" href="/Home/Scadenze" title="Scadenze e Alert">
                    <i class="bi bi-bell"></i>
                    @if (ViewData["AlertCount"] != null && (int)ViewData["AlertCount"]! > 0)
                    {
                        <span class="badge-count">@ViewData["AlertCount"]</span>
                    }
                </a>

                <!-- Nuova apparecchiatura rapida -->
                @if (User.IsInRole("EFM") || User.IsInRole("EDR") || User.IsInRole("ADMIN_ORG"))
                {
                    <a class="header-btn" href="/Apparecchiature/Create" title="Nuova Apparecchiatura">
                        <i class="bi bi-plus-circle"></i>
                    </a>
                }

                <!-- Avatar utente con dropdown -->
                <div class="dropdown">
                    <button class="user-avatar" data-bs-toggle="dropdown"
                            title="@User.Identity?.Name">
                        @{
                            var initials = "U";
                            if (User.Identity?.Name != null)
                            {
                                var parts = User.Identity.Name.Split('@')[0].Split('.');
                                initials = parts.Length >= 2
                                    ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
                                    : User.Identity.Name[..1].ToUpper();
                            }
                        }
                        @initials
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-1">
                        <li>
                            <div class="px-3 py-2 border-bottom">
                                <div class="fw-600 text-dark" style="font-size:0.875rem">
                                    @User.Identity?.Name
                                </div>
                                <div style="font-size:0.75rem; color:var(--neutral-500)">
                                    @(User.IsInRole("ADMIN_ORG") ? "Amministratore" :
                                      User.IsInRole("EFM") ? "Esperto Fisica Medica" :
                                      User.IsInRole("EDR") ? "Esperto di Radioprotezione" :
                                      User.IsInRole("RIR") ? "Responsabile Impianto" : "Utente")
                                </div>
                            </div>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/Account/Profile">
                                <i class="bi bi-person me-2"></i>Il mio profilo
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/Home/Scadenze">
                                <i class="bi bi-calendar-event me-2"></i>Le mie scadenze
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Esci
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>

            </div>
        </header>
        <!-- fine header -->

        <!-- ═══ CONTENUTO PRINCIPALE ══════════════════════════════ -->
        <main class="main-content">

            <!-- Toast notifiche da TempData -->
            @if (TempData["Success"] != null)
            {
                <div class="toast-container">
                    <div class="toast-item toast-success" id="toastSuccess">
                        <i class="bi bi-check-circle text-success"></i>
                        <span class="toast-msg">@TempData["Success"]</span>
                        <button class="toast-close" onclick="this.parentElement.remove()">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="toast-container">
                    <div class="toast-item toast-error" id="toastError">
                        <i class="bi bi-exclamation-circle text-danger"></i>
                        <span class="toast-msg">@TempData["Error"]</span>
                        <button class="toast-close" onclick="this.parentElement.remove()">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                </div>
            }

            @if (TempData["Warning"] != null)
            {
                <div class="toast-container">
                    <div class="toast-item toast-warning" id="toastWarning">
                        <i class="bi bi-exclamation-triangle text-warning"></i>
                        <span class="toast-msg">@TempData["Warning"]</span>
                        <button class="toast-close" onclick="this.parentElement.remove()">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                </div>
            }

            @RenderBody()

        </main>

    </div>
    <!-- fine app-wrapper -->
}
else
{
    <!-- Layout minimale per pagine non autenticate (login) -->
    <div class="d-flex min-vh-100 align-items-center justify-content-center"
         style="background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);">
        @RenderBody()
    </div>
}

<!-- ═══ SCRIPTS ══════════════════════════════════════════════════ -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
// ─── SIDEBAR TOGGLE ──────────────────────────────────────────────
const appWrapper   = document.getElementById('appWrapper');
const sidebarToggle = document.getElementById('sidebarToggle');

// Ripristina stato sidebar dal localStorage
if (localStorage.getItem('sidebarCollapsed') === 'true') {
    appWrapper?.classList.add('sidebar-collapsed');
}

sidebarToggle?.addEventListener('click', () => {
    appWrapper?.classList.toggle('sidebar-collapsed');
    localStorage.setItem(
        'sidebarCollapsed',
        appWrapper?.classList.contains('sidebar-collapsed') ? 'true' : 'false'
    );
});

// Mobile: overlay click chiude sidebar
document.addEventListener('click', (e) => {
    if (window.innerWidth <= 768) {
        const sidebar = document.getElementById('sidebar');
        if (sidebar && !sidebar.contains(e.target) && e.target !== sidebarToggle) {
            sidebar.classList.remove('mobile-open');
        }
    }
});

// ─── SUBMENU TOGGLE ──────────────────────────────────────────────
function toggleSubmenu(btn) {
    const navItem = btn.closest('.nav-item');
    const submenu = navItem.querySelector('.nav-submenu');
    const isOpen  = navItem.classList.contains('open');

    // Chiudi tutti gli altri
    document.querySelectorAll('.nav-item.open').forEach(item => {
        item.classList.remove('open');
        item.querySelector('.nav-submenu')?.classList.remove('open');
    });

    // Apri/chiudi questo
    if (!isOpen) {
        navItem.classList.add('open');
        submenu?.classList.add('open');
    }
}

// ─── AUTO-CHIUDI TOAST ───────────────────────────────────────────
document.querySelectorAll('.toast-item').forEach(toast => {
    setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.5s';
        setTimeout(() => toast.remove(), 500);
    }, 4000);
});

// ─── CONFERMA ELIMINAZIONE ───────────────────────────────────────
document.querySelectorAll('[data-confirm]').forEach(el => {
    el.addEventListener('click', (e) => {
        const msg = el.getAttribute('data-confirm') || 'Sei sicuro di voler procedere?';
        if (!confirm(msg)) e.preventDefault();
    });
});

// ─── TOOLTIP BOOTSTRAP ───────────────────────────────────────────
document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
    new bootstrap.Tooltip(el);
});
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>