@using Microsoft.AspNetCore.Identity
@using RadiologiaAppNew.Models
@using RadiologiaAppNew.Helpers
@inject UserManager<ApplicationUser> LayoutUserManager
@inject SignInManager<ApplicationUser> LayoutSignInManager

@{
    // ── Calcola moduli attivi per l'utente corrente ──────────────────
    List<string> _moduliAttivi = new();

    if (LayoutSignInManager.IsSignedIn(User))
    {
        var _currentUser = await LayoutUserManager.GetUserAsync(User);
        if (_currentUser != null)
        {
            var _ruoli = await LayoutUserManager.GetRolesAsync(_currentUser);
            _moduliAttivi = ModuliHelper.GetModuliEffettivi(
                _currentUser.ModuliAbilitati, _ruoli);
        }
    }

    bool _hasMod1 = _moduliAttivi.Contains(ModuliHelper.MOD1);
    bool _hasMod2 = _moduliAttivi.Contains(ModuliHelper.MOD2);
    bool _hasMod3 = _moduliAttivi.Contains(ModuliHelper.MOD3);
    bool _hasMod4 = _moduliAttivi.Contains(ModuliHelper.MOD4);

    string _ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string _action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RadiologiaApp</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />
    <!-- CSS custom -->
    <link rel="stylesheet" href="~/css/radiologia.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- ═══ APP WRAPPER ═══════════════════════════════════════════ -->
    <div class="app-wrapper" id="appWrapper">

        <!-- ═══ SIDEBAR ══════════════════════════════════════════ -->
        <aside class="sidebar" id="sidebar">

            <!-- Brand -->
            <a class="sidebar-brand" href="/">
                <div class="sidebar-brand-icon">
                    <i class="bi bi-radioactive"></i>
                </div>
                <div class="sidebar-brand-text">
                    <span class="app-name">RadiologiaApp</span>
                    <span class="app-subtitle">Fisica Sanitaria</span>
                </div>
            </a>

            <!-- Nav -->
            <nav class="sidebar-nav">

                <!-- Dashboard — sempre visibile -->
                <div class="nav-section-title">Generale</div>

                <div class="nav-item @(_ctrl == "Home" ? "active" : "")">
                    <a class="nav-link @(_ctrl == "Home" ? "active" : "")" href="/Home/Index">
                        <i class="bi bi-speedometer2 nav-icon"></i>
                        <span class="nav-label">Dashboard</span>
                    </a>
                </div>

                <!-- ─── MODULO 1 — Apparecchiature Radiologiche ─────── -->
                @if (_hasMod1)
                {
                    <div class="nav-section-title">
                        <i class="bi bi-radioactive me-1" style="font-size:0.65rem"></i>
                        Attrezzature medico-radiologiche<br> 
                        (D.lgs.101/20 s.m.i)
                    </div>

                    <div class="nav-item @(_ctrl == "Apparecchiature" ? "open" : "")">
                        <button class="nav-link @(_ctrl == "Apparecchiature" ? "active" : "")"
                                onclick="toggleSubmenu(this)">
                            <i class="bi bi-hdd-rack nav-icon"></i>
                            <span class="nav-label">Apparecchiature Radiologiche</span>
                            <i class="bi bi-chevron-right nav-arrow"></i>
                        </button>
                        <div class="nav-submenu @(_ctrl == "Apparecchiature" ? "open" : "")">
                            <div class="nav-item">
                                <a class="nav-link @(_action == "Index" && _ctrl == "Apparecchiature" ? "active" : "")"
                                   href="/Apparecchiature">
                                    <i class="bi bi-list-ul nav-icon"></i>
                                    <span class="nav-label">Inventario</span>
                                </a>
                            </div>
                            <div class="nav-item">
                                <a class="nav-link @(_action == "Create" && _ctrl == "Apparecchiature" ? "active" : "")"
                                   href="/Apparecchiature/Create">
                                    <i class="bi bi-plus-circle nav-icon"></i>
                                    <span class="nav-label">Nuova</span>
                                </a>
                            </div>
                            <div class="nav-item">
                                <a class="nav-link" href="/Apparecchiature?stato=Cessata">
                                    <i class="bi bi-archive nav-icon"></i>
                                    <span class="nav-label">Cessate</span>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="nav-item @(_ctrl == "Verifiche" ? "open" : "")">
                        <button class="nav-link @(_ctrl == "Verifiche" ? "active" : "")"
                                onclick="toggleSubmenu(this)">
                            <i class="bi bi-clipboard2-check nav-icon"></i>
                            <span class="nav-label">Garanzia della qualità</span>
                            <i class="bi bi-chevron-right nav-arrow"></i>
                        </button>
                        <div class="nav-submenu @(_ctrl == "Verifiche" ? "open" : "")">
                            <div class="nav-item">
                                <a class="nav-link" href="/Verifiche">
                                    <i class="bi bi-list-check nav-icon"></i>
                                    <span class="nav-label">Tutte le Verifiche</span>
                                </a>
                            </div>
                            <div class="nav-item">
                                <a class="nav-link" href="/Verifiche?tipo=Accettazione">
                                    <i class="bi bi-check2-circle nav-icon"></i>
                                    <span class="nav-label">Accettazioni</span>
                                </a>
                            </div>
                            <div class="nav-item">
                                <a class="nav-link" href="/Verifiche?tipo=Ldr">
                                    <i class="bi bi-graph-up nav-icon"></i>
                                    <span class="nav-label">LDR</span>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="nav-item @(_ctrl == "Adempimenti" ? "open" : "")">
                        <button class="nav-link @(_ctrl == "Adempimenti" ? "active" : "")"
                                onclick="toggleSubmenu(this)">
                            <i class="bi bi-file-earmark-text nav-icon"></i>
                            <span class="nav-label">Sorveglianza Fisica</span>
                            <i class="bi bi-chevron-right nav-arrow"></i>
                        </button>
                        <div class="nav-submenu @(_ctrl == "Adempimenti" ? "open" : "")">
                            <div class="nav-item">
                                <a class="nav-link" href="/Adempimenti/NotifichePratica">
                                    <i class="bi bi-send nav-icon"></i>
                                    <span class="nav-label">Notifiche di Pratica</span>
                                </a>
                            </div>
                            <div class="nav-item">
                                <a class="nav-link" href="/Adempimenti/NullaOsta">
                                    <i class="bi bi-shield-check nav-icon"></i>
                                    <span class="nav-label">Nulla Osta</span>
                                </a>
                            </div>
                            <div class="nav-item">
                                <a class="nav-link" href="/Adempimenti/Verbali">
                                    <i class="bi bi-journal-text nav-icon"></i>
                                    <span class="nav-label">Verbali Sopralluogo</span>
                                </a>
                            </div>
                        </div>
                    </div>
                }

                <!-- ─── MODULO 2 — Risonanza Magnetica ──────────────── -->
                @if (_hasMod2)
                {
                    <div class="nav-section-title">
                        <i class="bi bi-magnet me-1" style="font-size:0.65rem"></i>
                        Apparecchiature a Risonanza Magnetica<br>
                        (DM 14/01/21)
                    </div>

                    <div class="nav-item @(_ctrl == "Apparecchiature" && ViewData["IsRM"] != null ? "open" : "")">
                        <button class="nav-link @(_ctrl == "Apparecchiature" && ViewData["IsRM"] != null ? "active" : "")"
                                onclick="toggleSubmenu(this)">
                            <i class="bi bi-magnet nav-icon"></i>
                            <span class="nav-label">Apparecchiature RM</span>
                            <i class="bi bi-chevron-right nav-arrow"></i>
                        </button>
                        <div class="nav-submenu @(_ctrl == "Apparecchiature" && ViewData["IsRM"] != null ? "open" : "")">
                            <div class="nav-item">
                                <a class="nav-link @(_action == "IndexRM" ? "active" : "")"
                                   href="/Apparecchiature/IndexRM">
                                    <i class="bi bi-list-ul nav-icon"></i>
                                    <span class="nav-label">Inventario</span>
                                </a>
                            </div>
                            <div class="nav-item">
                                <a class="nav-link @(_action == "CreateRM" ? "active" : "")"
                                   href="/Apparecchiature/CreateRM">
                                    <i class="bi bi-plus-circle nav-icon"></i>
                                    <span class="nav-label">Nuova</span>
                                </a>
                            </div>
                            <div class="nav-item">
                                <a class="nav-link" href="/Apparecchiature/IndexRM?stato=Cessata">
                                    <i class="bi bi-archive nav-icon"></i>
                                    <span class="nav-label">Cessate</span>
                                </a>
                            </div>
                        </div>
                    </div>
                }

                <!-- ─── MODULO 3 — Medicina Nucleare ────────────────── -->
                @if (_hasMod3)
                {
                    <div class="nav-section-title">
                        <i class="bi bi-activity me-1" style="font-size:0.65rem"></i>
                        Modulo 3 — Med. Nucleare
                    </div>

                    <div class="nav-item">
                        <a class="nav-link @(_ctrl == "MedicinaNucleare" ? "active" : "")"
                           href="/MedicinaNucleare">
                            <i class="bi bi-radioactive nav-icon"></i>
                            <span class="nav-label">Registri MN</span>
                        </a>
                    </div>
                }

                <!-- ─── MODULO 4 — Lu177 ─────────────────────────────── -->
                @if (_hasMod4)
                {
                    <div class="nav-section-title">
                        <i class="bi bi-heart-pulse me-1" style="font-size:0.65rem"></i>
                        Modulo 4 — Lu177
                    </div>

                    <div class="nav-item @(_ctrl == "Lu177" ? "open" : "")">
                        <button class="nav-link @(_ctrl == "Lu177" ? "active" : "")"
                                onclick="toggleSubmenu(this)">
                            <i class="bi bi-person-heart nav-icon"></i>
                            <span class="nav-label">Terapia Lu177</span>
                            <i class="bi bi-chevron-right nav-arrow"></i>
                        </button>
                        <div class="nav-submenu @(_ctrl == "Lu177" ? "open" : "")">
                            <div class="nav-item">
                                <a class="nav-link" href="/Lu177">
                                    <i class="bi bi-people nav-icon"></i>
                                    <span class="nav-label">Pazienti</span>
                                </a>
                            </div>
                            <div class="nav-item">
                                <a class="nav-link" href="/Lu177/Statistiche">
                                    <i class="bi bi-bar-chart nav-icon"></i>
                                    <span class="nav-label">Statistiche Cliniche</span>
                                </a>
                            </div>
                        </div>
                    </div>
                }

                <!-- ─── Amministrazione ──────────────────────────────── -->
                @if (User.IsInRole("ADMIN_ORG") || User.IsInRole("SUPER_ADMIN"))
                {
                    <div class="nav-section-title">Amministrazione</div>

                    <div class="nav-item">
                        <a class="nav-link @(_ctrl == "Utenti" ? "active" : "")"
                           href="/Utenti">
                            <i class="bi bi-people nav-icon"></i>
                            <span class="nav-label">Gestione Utenti</span>
                        </a>
                    </div>

                    <div class="nav-item">
                        <a class="nav-link @(_ctrl == "Configurazione" ? "active" : "")"
                           href="/Configurazione">
                            <i class="bi bi-gear nav-icon"></i>
                            <span class="nav-label">Configurazione</span>
                        </a>
                    </div>
                }

            </nav>

            <!-- Footer sidebar -->
            <div class="sidebar-footer">
                <div class="sidebar-footer-text">
                    RadiologiaApp v1.0<br />
                    D.Lgs. 101/20 — DM 01/21
                </div>
            </div>

        </aside>
        <!-- fine sidebar -->

        <!-- ═══ HEADER ════════════════════════════════════════════ -->
        <header class="app-header">

            <!-- Toggle sidebar -->
            <button class="header-toggle" id="sidebarToggle" title="Espandi/Comprimi menu">
                <i class="bi bi-list"></i>
            </button>

            <!-- Breadcrumb -->
            <nav class="header-breadcrumb">
                <a href="/">
                    <i class="bi bi-house"></i>
                </a>
                @if (ViewData["BreadcrumbParent"] != null)
                {
                    <span class="bc-separator">/</span>
                    @if (ViewData["BreadcrumbParentUrl"] != null)
                    {
                        <a href="@ViewData["BreadcrumbParentUrl"]">@ViewData["BreadcrumbParent"]</a>
                    }
                    else
                    {
                        <span>@ViewData["BreadcrumbParent"]</span>
                    }
                }
                @if (ViewData["Title"] != null)
                {
                    <span class="bc-separator">/</span>
                    <span class="bc-current">@ViewData["Title"]</span>
                }
            </nav>

            <!-- Azioni header -->
            <div class="header-actions">

                <!-- Notifiche -->
                <a class="header-btn" href="/Home/Scadenze" title="Scadenze e Alert">
                    <i class="bi bi-bell"></i>
                    @if (ViewData["AlertCount"] != null && (int)ViewData["AlertCount"]! > 0)
                    {
                        <span class="badge-count">@ViewData["AlertCount"]</span>
                    }
                </a>

                <!-- Nuova apparecchiatura rapida — dropdown se MOD1 e/o MOD2 abilitati -->
                @{
                    bool _puoCreare = User.IsInRole("EFM") || User.IsInRole("EDR") ||
                                      User.IsInRole("ADMIN_ORG") || User.IsInRole("ES") ||
                                      User.IsInRole("MR");
                    bool _showPlus  = _puoCreare && (_hasMod1 || _hasMod2);
                }
                @if (_showPlus)
                {
                    @if (_hasMod1 && _hasMod2)
                    {
                        <!-- Entrambi i moduli — dropdown di scelta -->
                        <div class="dropdown">
                            <button class="header-btn" data-bs-toggle="dropdown"
                                    title="Nuova Apparecchiatura">
                                <i class="bi bi-plus-circle"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-1">
                                <li>
                                    <h6 class="dropdown-header"
                                        style="font-size:0.75rem;">Nuova apparecchiatura</h6>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Apparecchiature/Create">
                                        <i class="bi bi-radioactive me-2 text-primary"></i>
                                        Radiologica (D.Lgs.101/20)
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Apparecchiature/CreateRM">
                                        <i class="bi bi-magnet me-2"
                                           style="color:#8e44ad"></i>
                                        Risonanza Magnetica (DM 14/01/21)
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else if (_hasMod1)
                    {
                        <a class="header-btn" href="/Apparecchiature/Create"
                           title="Nuova Apparecchiatura Radiologica">
                            <i class="bi bi-plus-circle"></i>
                        </a>
                    }
                    else
                    {
                        <a class="header-btn" href="/Apparecchiature/CreateRM"
                           title="Nuova Apparecchiatura RM">
                            <i class="bi bi-plus-circle"></i>
                        </a>
                    }
                }

                <!-- Avatar utente con dropdown -->
                <div class="dropdown">
                    <button class="user-avatar" data-bs-toggle="dropdown"
                            title="@User.Identity?.Name">
                        @{
                            var initials = "U";
                            if (User.Identity?.Name != null)
                            {
                                var parts = User.Identity.Name.Split('@')[0].Split('.');
                                initials = parts.Length >= 2
                                    ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
                                    : User.Identity.Name[..1].ToUpper();
                            }
                        }
                        @initials
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-1">
                        <li>
                            <div class="px-3 py-2 border-bottom">
                                <div class="fw-600 text-dark" style="font-size:0.875rem">
                                    @User.Identity?.Name
                                </div>
                                <div style="font-size:0.75rem; color:var(--neutral-500)">
                                    @(User.IsInRole("ADMIN_ORG") ? "Amministratore" :
                                      User.IsInRole("EFM") ? "Esperto Fisica Medica" :
                                      User.IsInRole("EDR") ? "Esperto di Radioprotezione" :
                                      User.IsInRole("RIR") ? "Responsabile Impianto" : "Utente")
                                </div>
                                @if (_moduliAttivi.Any())
                                {
                                    <div style="font-size:0.7rem; color:var(--neutral-400); margin-top:2px">
                                        @string.Join(" · ", _moduliAttivi)
                                    </div>
                                }
                            </div>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/Account/Profile">
                                <i class="bi bi-person me-2"></i>Il mio profilo
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/Home/Scadenze">
                                <i class="bi bi-calendar-event me-2"></i>Le mie scadenze
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Esci
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>

            </div>
        </header>
        <!-- fine header -->

        <!-- ═══ CONTENUTO PRINCIPALE ══════════════════════════════ -->
        <main class="main-content">

            <!-- Toast notifiche da TempData -->
            @if (TempData["Success"] != null)
            {
                <div class="toast-container">
                    <div class="toast-item toast-success" id="toastSuccess">
                        <i class="bi bi-check-circle text-success"></i>
                        <span class="toast-msg">@TempData["Success"]</span>
                        <button class="toast-close" onclick="this.parentElement.remove()">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="toast-container">
                    <div class="toast-item toast-error" id="toastError">
                        <i class="bi bi-exclamation-circle text-danger"></i>
                        <span class="toast-msg">@TempData["Error"]</span>
                        <button class="toast-close" onclick="this.parentElement.remove()">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                </div>
            }

            @if (TempData["Warning"] != null)
            {
                <div class="toast-container">
                    <div class="toast-item toast-warning" id="toastWarning">
                        <i class="bi bi-exclamation-triangle text-warning"></i>
                        <span class="toast-msg">@TempData["Warning"]</span>
                        <button class="toast-close" onclick="this.parentElement.remove()">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                </div>
            }

            @RenderBody()

        </main>

    </div>
    <!-- fine app-wrapper -->
}
else
{
    <!-- Layout minimale per pagine non autenticate (login) -->
    <div class="d-flex min-vh-100 align-items-center justify-content-center"
         style="background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);">
        @RenderBody()
    </div>
}

<!-- ═══ SCRIPTS ══════════════════════════════════════════════════ -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
// ─── SIDEBAR TOGGLE ──────────────────────────────────────────────
const appWrapper    = document.getElementById('appWrapper');
const sidebarToggle = document.getElementById('sidebarToggle');

if (localStorage.getItem('sidebarCollapsed') === 'true') {
    appWrapper?.classList.add('sidebar-collapsed');
}

sidebarToggle?.addEventListener('click', () => {
    appWrapper?.classList.toggle('sidebar-collapsed');
    localStorage.setItem(
        'sidebarCollapsed',
        appWrapper?.classList.contains('sidebar-collapsed') ? 'true' : 'false'
    );
});

document.addEventListener('click', (e) => {
    if (window.innerWidth <= 768) {
        const sidebar = document.getElementById('sidebar');
        if (sidebar && !sidebar.contains(e.target) && e.target !== sidebarToggle) {
            sidebar.classList.remove('mobile-open');
        }
    }
});

// ─── SUBMENU TOGGLE ──────────────────────────────────────────────
function toggleSubmenu(btn) {
    const navItem = btn.closest('.nav-item');
    const submenu = navItem.querySelector('.nav-submenu');
    const isOpen  = navItem.classList.contains('open');

    document.querySelectorAll('.nav-item.open').forEach(item => {
        item.classList.remove('open');
        item.querySelector('.nav-submenu')?.classList.remove('open');
    });

    if (!isOpen) {
        navItem.classList.add('open');
        submenu?.classList.add('open');
    }
}

// ─── AUTO-CHIUDI TOAST ───────────────────────────────────────────
document.querySelectorAll('.toast-item').forEach(toast => {
    setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.5s';
        setTimeout(() => toast.remove(), 500);
    }, 4000);
});

// ─── CONFERMA ELIMINAZIONE ───────────────────────────────────────
document.querySelectorAll('[data-confirm]').forEach(el => {
    el.addEventListener('click', (e) => {
        const msg = el.getAttribute('data-confirm') || 'Sei sicuro di voler procedere?';
        if (!confirm(msg)) e.preventDefault();
    });
});

// ─── TOOLTIP BOOTSTRAP ───────────────────────────────────────────
document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
    new bootstrap.Tooltip(el);
});
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
