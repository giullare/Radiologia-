<div class="tab-panel @(Model.TabAttiva == "statistiche" ? "active" : "")"
     id="tab-statistiche">

    @if (!Model.VerificheCQ.Any())
    {
        <div class="empty-state">
            <i class="bi bi-bar-chart empty-state-icon"></i>
