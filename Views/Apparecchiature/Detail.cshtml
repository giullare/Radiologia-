@model RadiologiaAppNew.ViewModels.Apparecchiature.ApparecchiaturaDetailViewModel
@{
    Layout = "_Layout";
    var app = Model.Apparecchiatura;
    ViewData["Title"] = app.Descrizione;
}

<!-- ═══ PAGE HEADER ══════════════════════════════════════════════ -->
<div class="page-header">
    <div>
        <div class="d-flex align-items-center gap-2 mb-1">
            <code style="font-size:0.8rem;background:var(--neutral-100);
                         padding:2px 8px;border-radius:4px;">
                @app.Codice
            </code>
            @{
                var (statoClass, statoLabel) = app.Stato switch
                {
                    RadiologiaAppNew.Enums.StatoApparecchiatura.Attiva =>
                        ("stato-attiva", "Attiva"),
                    RadiologiaAppNew.Enums.StatoApparecchiatura.InInstallazione =>
                        ("stato-in-installazione", "In Installazione"),
                    RadiologiaAppNew.Enums.StatoApparecchiatura.InManutenzione =>
                        ("stato-in-manutenzione", "In Manutenzione"),
                    RadiologiaAppNew.Enums.StatoApparecchiatura.Cessata =>
                        ("stato-cessata", "Cessata"),
                    _ => ("stato-cessata", app.Stato.ToString())
                };
            }
            <span class="stato-badge @statoClass">@statoLabel</span>
        </div>
        <h1 class="page-title">@app.Descrizione</h1>
        <p class="page-subtitle">
            @app.Costruttore — @app.Modello
            @if (app.Reparto != null)
            {
                <span> · @app.Reparto.Nome</span>
            }
        </p>
    </div>
    <div class="page-actions">
        <a href="/Apparecchiature" class="btn btn-ghost">
            <i class="bi bi-arrow-left"></i> Inventario
        </a>
        <a href="/Apparecchiature/Stampa/@app.Id" target="_blank" class="btn btn-ghost">
            <i class="bi bi-printer"></i> Stampa
        </a>
        @if (User.IsInRole("ADMIN_ORG") || User.IsInRole("EFM") || User.IsInRole("EDR"))
        {
            <a href="/Apparecchiature/Edit/@app.Id" class="btn btn-outline">
                <i class="bi bi-pencil"></i> Modifica
            </a>
        }
        <a href="/Verifiche/Create/@app.Id" class="btn btn-primary">
            <i class="bi bi-clipboard2-plus"></i> Nuova Verifica
        </a>
    </div>
</div>

<!-- ═══ TAB NAVIGATION ═══════════════════════════════════════════ -->
<div class="tabs-radiologia">
    <button class="tab-btn @(Model.TabAttiva == "anagrafica" ? "active" : "")"
            onclick="switchTab('anagrafica')">
        <i class="bi bi-info-circle"></i>
        Anagrafica
    </button>
   
    <button class="tab-btn @(Model.TabAttiva == "verifiche" ? "active" : "")"
            onclick="switchTab('verifiche')">
        <i class="bi bi-clipboard2-check"></i>
        Garanzia della qualità
        <span style="background:var(--neutral-200);color:var(--neutral-700);
                     border-radius:10px;padding:1px 6px;font-size:0.7rem;">
            @Model.VerificheCQ.Count
        </span>
    </button>
    <button class="tab-btn @(Model.TabAttiva == "adempimenti" ? "active" : "")"
            onclick="switchTab('adempimenti')">
        <i class="bi bi-file-earmark-text"></i>
        Sorveglianza Fisica
    </button>
     <button class="tab-btn @(Model.TabAttiva == "compliance" ? "active" : "")"
            onclick="switchTab('compliance')">
        <i class="bi bi-shield-check"></i>
        Summary
        @{
            var critici = Model.ItemsCompliance.Count(i => i.Stato == "danger");
            var warning = Model.ItemsCompliance.Count(i => i.Stato == "warning");
        }
        @if (critici > 0)
        {
            <span style="background:var(--danger);color:white;
                         border-radius:10px;padding:1px 6px;
                         font-size:0.7rem;font-weight:700;">
                @critici
            </span>
        }
        else if (warning > 0)
        {
            <span style="background:var(--warning);color:white;
                         border-radius:10px;padding:1px 6px;
                         font-size:0.7rem;font-weight:700;">
                @warning
            </span>
        }
    </button>
    <button class="tab-btn @(Model.TabAttiva == "documenti" ? "active" : "")"
            onclick="switchTab('documenti')">
        <i class="bi bi-paperclip"></i>
        Documenti
        <span style="background:var(--neutral-200);color:var(--neutral-700);
                     border-radius:10px;padding:1px 6px;font-size:0.7rem;">
            @Model.FileAllegati.Count
        </span>
    </button>
    <button class="tab-btn @(Model.TabAttiva == "statistiche" ? "active" : "")"
            onclick="switchTab('statistiche')">
        <i class="bi bi-bar-chart"></i>
        Statistiche
    </button>
</div>

<!-- ═══ TAB: ANAGRAFICA ══════════════════════════════════════════ -->
<div class="tab-panel @(Model.TabAttiva == "anagrafica" ? "active" : "")"
     id="tab-anagrafica">

    <!-- ── RIGA 1: Dati identificativi ──────────────────────────── -->
    <div class="form-section mb-3">
        <div class="form-section-header">
            <i class="bi bi-card-list text-primary"></i>
            <h4 class="form-section-title">Dati Identificativi</h4>
        </div>
        <div class="form-section-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="form-label">Ambito</div>
                    <div class="fw-600">@(app.AmbitoIntervento?.ToString() ?? "—")</div>
                </div>
                <div class="col-md-3">
                    <div class="form-label">Tipologia</div>
                    <div class="fw-600">@app.Tipologia</div>
                </div>
                <div class="col-md-3">
                    <div class="form-label">Costruttore</div>
                    <div class="fw-600">@app.Costruttore</div>
                </div>
                <div class="col-md-3">
                    <div class="form-label">Modello</div>
                    <div class="fw-600">@app.Modello</div>
                </div>
                <div class="col-md-3">
                    <div class="form-label">Matricola</div>
                    <div class="fw-600">@app.Matricola</div>
                </div>
                @if (!string.IsNullOrEmpty(app.SerialNumber))
                {
                    <div class="col-md-3">
                        <div class="form-label">Numero Seriale</div>
                        <div class="fw-600">@app.SerialNumber</div>
                    </div>
                }
                <div class="col-md-3">
                    <div class="form-label">Data Accettazione</div>
                    <div class="fw-600">
                        @(app.DataAccettazione.HasValue
                            ? app.DataAccettazione.Value.ToString("dd/MM/yyyy") : "—")
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(app.SapId))
                {
                    <div class="col-md-3">
                        <div class="form-label">Codice Cespite (SAP)</div>
                        <div class="fw-600">@app.SapId</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(app.SiapDescrizione))
                {
                    <div class="col-md-3">
                        <div class="form-label">Codice Terminale (SIA)</div>
                        <div class="fw-600">@app.SiapDescrizione</div>
                    </div>
                }
                <div class="col-md-3">
                    <div class="form-label">LAN Collegata</div>
                    <span class="badge-compliance @(app.LanCollegata ? "badge-ok" : "badge-missing")">
                        @(app.LanCollegata ? "Sì" : "No")
                    </span>
                </div>
                <div class="col-md-3">
                    <div class="form-label">SW Monitoraggio Dose</div>
                    <span class="badge-compliance @(app.MedsquareInstallato ? "badge-ok" : "badge-missing")">
                        @(app.MedsquareInstallato ? "Sì" : "No")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── RIGA 2: Parametri Tecnici ────────────────────────────── -->
    @if (app.CorrenteMaxMa.HasValue || app.TensioneMaxKvolt.HasValue ||
         app.EnergiaMaxKev.HasValue || app.IntensitaCampoTesla.HasValue)
    {
        <div class="form-section mb-3">
            <div class="form-section-header">
                <i class="bi bi-lightning-charge text-primary"></i>
                <h4 class="form-section-title">Parametri Tecnici</h4>
            </div>
            <div class="form-section-body">
                <div class="row g-3">
                    @if (app.CorrenteMaxMa.HasValue)
                    {
                        <div class="col-md-3">
                            <div class="form-label">Corrente Max</div>
                            <div class="fw-600">@app.CorrenteMaxMa mA</div>
                        </div>
                    }
                    @if (app.TensioneMaxKvolt.HasValue)
                    {
                        <div class="col-md-3">
                            <div class="form-label">Tensione Max</div>
                            <div class="fw-600">@app.TensioneMaxKvolt kV</div>
                        </div>
                    }
                    @if (app.EnergiaMaxKev.HasValue)
                    {
                        <div class="col-md-3">
                            <div class="form-label">Energia Max</div>
                            <div class="fw-600">@app.EnergiaMaxKev keV</div>
                        </div>
                    }
                    @if (app.IntensitaCampoTesla.HasValue)
                    {
                        <div class="col-md-3">
                            <div class="form-label">Intensità Campo</div>
                            <div class="fw-600">@app.IntensitaCampoTesla T</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(app.TipoMagnete))
                    {
                        <div class="col-md-3">
                            <div class="form-label">Tipo Magnete</div>
                            <div class="fw-600">@app.TipoMagnete</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- ── RIGA 3: Collocazione ──────────────────────────────────── -->
    <div class="form-section mb-3">
        <div class="form-section-header">
            <i class="bi bi-geo-alt text-primary"></i>
            <h4 class="form-section-title">Collocazione Fisica</h4>
        </div>
        <div class="form-section-body">
            <div class="row g-3">
               
                @if (app.Locale != null)
{
    <div class="col-md-3">
        <div class="form-label">Collocazione</div>

        <div class="fw-600">

            @if (app.Locale?.Piano?.Immobile?.Sito != null)
            {
                <div>
                    <strong>Sito / Presidio:</strong>
                    @app.Locale.Piano.Immobile.Sito.Nome
                </div>
            }

            @if (app.Locale?.Piano?.Immobile != null)
            {
                <div>
                    <strong>Edificio:</strong>
                    @app.Locale.Piano.Immobile.Nome
                </div>
            }

            @if (app.Locale?.Piano != null)
            {
                <div>
                    <strong>Piano:</strong>
                    @app.Locale.Piano.Nome
                </div>
            }

            <div>
                <strong>Locale / Stanza:</strong>
                @app.Locale.Nome

                @if (!string.IsNullOrEmpty(app.Locale.Codice))
                {
                    <span style="font-size:0.8rem;color:var(--neutral-500)">
                        (@app.Locale.Codice)
                    </span>
                }
            </div>

        </div>
    </div>
}
 @if (app.Reparto != null)
                {
                    <div class="col-md-3">
                        <div class="form-label">Struttura</div>
                        <div class="fw-600">@app.Reparto.Nome</div>
                    </div>
                }
                @if (app.Dipartimento != null)
                {
                    <div class="col-md-3">
                        <div class="form-label">Dipartimento</div>
                        <div class="fw-600">@app.Dipartimento.Nome</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(app.DescrizioneZoneClassificate))
                {
                    <div class="col-12">
                        <div class="form-label">Zone Classificate</div>
                        <div style="font-size:0.875rem;">@app.DescrizioneZoneClassificate</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(app.PiantinaZoneClassificateFile))
                {
                    <div class="col-md-4">
                    <div class="form-label">Piantina Zone Classificate</div>
                        <a href="@app.PiantinaZoneClassificateFile" target="_blank"
                           class="btn btn-ghost btn-sm">
                            <i class="bi bi-map"></i>
                            @System.IO.Path.GetFileName(app.PiantinaZoneClassificateFile)
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── RIGA 4: Responsabili ──────────────────────────────────── -->
    <div class="form-section mb-3">
        <div class="form-section-header">
            <i class="bi bi-people text-primary"></i>
            <h4 class="form-section-title">Responsabili</h4>
        </div>
        <div class="form-section-body p-0">
            @{
               var responsabiliInline = new List<(string Ruolo, string? Nome, string? Email, string? Pec, string? Tel)>
{
    ("Direttore Dipartimento", app.DirettoreDipartimento, app.DirettoreDipartimentoEmail, app.DirettoreDipartimentoEmailPec, app.DirettoreDipartimentoTelefono),
    ("Direttore Struttura", app.DirettoreStruttura, app.DirettoreStrutturaEmail, app.DirettoreStrutturaEmailPec, app.DirettoreStrutturaTelefono),
    ("Preposto D.Lgs 101/20", app.Caposala, app.PrepostoEmail, app.PrepostoEmailPec, app.PrepostoTelefono),
    ("Responsabile Impianto Radiologico (RIR)", app.RirNome, app.RirEmail, app.RirEmailPec, app.RirTelefono),
    ("Specialista in Fisica Medica (SFM)", app.SfmNome, app.SfmEmail, app.SfmEmailPec, app.SfmTelefono),
    ("Esperto di Radioprotezione (EdR)", app.EdrNome, app.EdrEmail, app.EdrEmailPec, app.EdrTelefono),
};
            }

            @if (!responsabiliInline.Any(r => !string.IsNullOrEmpty(r.Nome)))
            {
                <div style="padding:16px 20px;color:var(--neutral-400);font-size:0.875rem;">
                    Nessun responsabile inserito. <a href="/Apparecchiature/Edit/@app.Id#step-3">Modifica per aggiungere</a>
                </div>
            }
            else
            {
                <table style="width:100%;border-collapse:collapse;">
                    <thead>
                        <tr style="background:var(--neutral-50);border-bottom:2px solid var(--neutral-200);">
                            <th style="padding:8px 16px;font-size:0.75rem;font-weight:700;
                                       text-transform:uppercase;letter-spacing:.04em;
                                       color:var(--neutral-500);width:28%">Ruolo</th>
                            <th style="padding:8px 16px;font-size:0.75rem;font-weight:700;
                                       text-transform:uppercase;letter-spacing:.04em;
                                       color:var(--neutral-500)">Nome</th>
                            <th style="padding:8px 16px;font-size:0.75rem;font-weight:700;
                                       text-transform:uppercase;letter-spacing:.04em;
                                       color:var(--neutral-500)">Email</th>
                            <th style="padding:8px 16px;font-size:0.75rem;font-weight:700;
                                       text-transform:uppercase;letter-spacing:.04em;
                                       color:var(--neutral-500)">PEC</th>
                            <th style="padding:8px 16px;font-size:0.75rem;font-weight:700;
                                       text-transform:uppercase;letter-spacing:.04em;
                                       color:var(--neutral-500)">Telefono</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in responsabiliInline)
                        {
                            <tr style="border-bottom:1px solid var(--neutral-100);
                                       @(string.IsNullOrEmpty(r.Nome) ? "opacity:0.4" : "")">
                                <td style="padding:10px 16px;">
                                    <span style="font-size:0.82rem;font-weight:600;
                                                 color:var(--primary)">@r.Ruolo</span>
                                </td>
                                <td style="padding:10px 16px;">
                                    <span style="font-size:0.875rem;font-weight:500;">
                                        @(string.IsNullOrEmpty(r.Nome) ? "—" : r.Nome)
                                    </span>
                                </td>
                                <td style="padding:10px 16px;">
                                    @if (!string.IsNullOrEmpty(r.Email))
                                    {
                                        <a href="mailto:@r.Email"
                                           style="font-size:0.82rem;color:var(--primary)">
                                            @r.Email
                                        </a>
                                    }
                                    else { <span style="color:var(--neutral-300);font-size:0.82rem">—</span> }
                                </td>
                                <td style="padding:10px 16px;">
                                    @if (!string.IsNullOrEmpty(r.Pec))
                                    {
                                        <a href="mailto:@r.Pec"
                                           style="font-size:0.82rem;color:var(--primary)">
                                            @r.Pec
                                        </a>
                                    }
                                    else { <span style="color:var(--neutral-300);font-size:0.82rem">—</span> }
                                </td>
                                <td style="padding:10px 16px;">
                                    @if (!string.IsNullOrEmpty(r.Tel))
                                    {
                                        <a href="tel:@r.Tel"
                                           style="font-size:0.82rem;color:var(--neutral-600)">
                                            @r.Tel
                                        </a>
                                    }
                                    else { <span style="color:var(--neutral-300);font-size:0.82rem">—</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- ── RIGA 5: Assistenza e Manutenzione ────────────────────── -->
    <div class="form-section mb-3">
        <div class="form-section-header">
            <i class="bi bi-tools text-primary"></i>
            <h4 class="form-section-title">Assistenza e Manutenzione</h4>
        </div>
        <div class="form-section-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="form-label">Società di Manutenzione</div>
                    <div class="fw-600">
                        @(string.IsNullOrEmpty(app.SocietaManutenzione) ? "—" : app.SocietaManutenzione)
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-label">Tecnico di Riferimento</div>
                    <div class="fw-600">
                        @(string.IsNullOrEmpty(app.TecnicoRiferimento) ? "—" : app.TecnicoRiferimento)
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-label">Nr. Assistenza Tecnica</div>
                    <div class="fw-600">
                        @if (!string.IsNullOrEmpty(app.NumeroAssistenza))
                        {
                            <a href="tel:@app.NumeroAssistenza">@app.NumeroAssistenza</a>
                        }
                        else { <span>—</span> }
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-label">Global Service</div>
                    <div class="fw-600">
                        @(string.IsNullOrEmpty(app.GlobalService) ? "—" : app.GlobalService)
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-label">Email Assistenza</div>
                    <div class="fw-600">
                        @if (!string.IsNullOrEmpty(app.EmailAssistenza))
                        {
                            <a href="mailto:@app.EmailAssistenza">@app.EmailAssistenza</a>
                        }
                        else { <span>—</span> }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── RIGA 6: Tracciabilità e Denuncia ─────────────────────── -->
    <div class="form-section mb-3">
        <div class="form-section-header">
            <i class="bi bi-building-check text-primary"></i>
            <h4 class="form-section-title">Tracciabilità e Denuncia di Messa in Servizio</h4>
        </div>
        <div class="form-section-body">
            <div class="row g-4">

                <!-- STRIMS -->
                <div class="col-md-6">
                    <div style="padding:14px;background:var(--neutral-50);
                                border-radius:8px;border:1px solid var(--neutral-200);height:100%">
                        <div style="font-weight:700;color:var(--primary);
                                    margin-bottom:10px;font-size:0.9rem;">
                            <i class="bi bi-database-check me-2"></i>Registrazione STRIMS
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="form-label">Stato</div>
                                <span class="badge-compliance
                                    @(app.StatoStrims == RadiologiaAppNew.Enums.StatoAdempimento.Registrato
                                        ? "badge-ok" : "badge-todo")">
                                    @(app.StatoStrims == RadiologiaAppNew.Enums.StatoAdempimento.Registrato ? "Registrato"
                                      : app.StatoStrims == RadiologiaAppNew.Enums.StatoAdempimento.NonApplicabile ? "Non Applicabile"
                                      : "Da Registrare")
                                </span>
                            </div>
                            <div class="col-6">
                                <div class="form-label">ID STRIMS</div>
                                <div class="fw-600" style="font-size:0.875rem">
                                    @(string.IsNullOrEmpty(app.StrimsIdApparecchiatura) ? "—" : app.StrimsIdApparecchiatura)
                                </div>
                            </div>
                            @if (app.DataRegistrazioneStrims.HasValue)
                            {
                                <div class="col-6">
                                    <div class="form-label">Data Registrazione</div>
                                    <div class="fw-600" style="font-size:0.875rem">
                                        @app.DataRegistrazioneStrims.Value.ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                            }
                            <div class="col-6">
                                <div class="form-label">Notifica di Pratica e DVR</div>
                                <span class="badge-compliance @(app.StrimsNpCaricata ? "badge-ok" : "badge-missing")"
                                      style="font-size:0.75rem">
                                    @(app.StrimsNpCaricata ? "✓ Caricata" : "Non caricata")
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(app.StrimsRicevutaRegistrazioneFile))
                            {
                                <div class="col-12">
                                    <div class="form-label">Ricevuta Registrazione</div>
                                    <a href="@app.StrimsRicevutaRegistrazioneFile" target="_blank"
                                       class="btn btn-ghost btn-sm" style="font-size:0.78rem">
                                        <i class="bi bi-file-earmark-pdf text-danger"></i>
                                        @System.IO.Path.GetFileName(app.StrimsRicevutaRegistrazioneFile)
                                    </a>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(app.StrimsRicevutaCessioneFile))
                            {
                                <div class="col-12">
                                    <div class="form-label">Ricevuta Cessazione</div>
                                    <a href="@app.StrimsRicevutaCessioneFile" target="_blank"
                                       class="btn btn-ghost btn-sm" style="font-size:0.78rem">
                                        <i class="bi bi-file-earmark-pdf text-danger"></i>
                                        @System.IO.Path.GetFileName(app.StrimsRicevutaCessioneFile)
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- INAIL -->
                <div class="col-md-6">
                    <div style="padding:14px;background:var(--neutral-50);
                                border-radius:8px;border:1px solid var(--neutral-200);height:100%">
                        <div style="font-weight:700;color:var(--primary);
                                    margin-bottom:10px;font-size:0.9rem;">
                            <i class="bi bi-building-check me-2"></i>Registrazione INAIL
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="form-label">Stato</div>
                                <span class="badge-compliance
                                    @(app.StatoInail == RadiologiaAppNew.Enums.StatoAdempimento.Registrato
                                        ? "badge-ok" : "badge-todo")">
                                    @(app.StatoInail == RadiologiaAppNew.Enums.StatoAdempimento.Registrato ? "Registrato"
