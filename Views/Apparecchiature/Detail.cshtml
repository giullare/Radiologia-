@section Scripts {
<script>
// ─── TAB SWITCH ──────────────────────────────────────────────────
function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach(b =>
        b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p =>
        p.classList.remove('active'));

    document.querySelector(`#tab-${name}`)?.classList.add('active');
    event.currentTarget.classList.add('active');

    history.replaceState(null, '',
        `?tab=${name}`);
}

@if (Model.VerificheCQ.Any())
{
    <text>
    const PALETTE = {
        Positivi: 'rgba(39,174,96,0.85)',
        Negativi: 'rgba(192,57,43,0.85)',
        Riserva:  'rgba(243,156,18,0.85)',
        InCorso:  'rgba(100,116,139,0.85)'
    };

    // ───────────────────────── Grafico a barre (per tipo verifica) ─────────────────────────
    const ctxAnno = document.getElementById('chartEsitiAnno');
    if (ctxAnno) {
        @{
            var labels   = Model.StatistichePerTipo.Select(s => s.Tipo).ToList();
            var positivi = Model.StatistichePerTipo.Select(s => s.Positivi).ToList();
            var negativi = Model.StatistichePerTipo.Select(s => s.Negativi).ToList();
            var riserva  = Model.StatistichePerTipo.Select(s => s.PositivoConRiserva).ToList();
            var inCorso  = Model.StatistichePerTipo.Select(s => s.InCorso).ToList();
        }
        const barLabels   = @Html.Raw(Json.Serialize(labels));
        const barPositivi = @Html.Raw(Json.Serialize(positivi));
        const barNegativi = @Html.Raw(Json.Serialize(negativi));
        const barRiserva  = @Html.Raw(Json.Serialize(riserva));
        const barInCorso  = @Html.Raw(Json.Serialize(inCorso));

        const barTotals = barLabels.map((_, i) =>
            barPositivi[i] + barNegativi[i] + barRiserva[i] + barInCorso[i]);

        new Chart(ctxAnno, {
            type: 'bar',
            data: {
                labels: barLabels,
                datasets: [
                    { label: 'Positivi', data: barPositivi, backgroundColor: PALETTE.Positivi, borderRadius: 4 },
                    { label: 'Negativi', data: barNegativi, backgroundColor: PALETTE.Negativi, borderRadius: 4 },
                    { label: 'Positivi con riserva', data: barRiserva, backgroundColor: PALETTE.Riserva, borderRadius: 4 },
                    { label: 'In Corso', data: barInCorso, backgroundColor: PALETTE.InCorso, borderRadius: 4 }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { usePointStyle: true, font: { size: 11 } }
                    },
                    tooltip: {
                        callbacks: {
                            label: function (ctx) {
                                const val = ctx.parsed.y;
                                const tot = barTotals[ctx.dataIndex] || 0;
                                const pct = tot > 0 ? ((val / tot) * 100).toFixed(0) : 0;
                                return val > 0 ? `${ctx.dataset.label}: ${val} (${pct}%)` : null;
                            },
                            footer: function (items) {
                                const tot = barTotals[items[0].dataIndex] || 0;
                                return `Totale: ${tot}`;
                            }
                        }
                    }
                },
                scales: {
                    x: { stacked: true, ticks: { autoSkip: false, maxRotation: 0 }, grid: { display: false } },
                    y: { stacked: true, beginAtZero: true, ticks: { precision: 0 } }
                }
            }
        });
    }

    // ───────────────────────── Grafico a torta (distribuzione per tipo selezionato) ─────────────────────────
    const ctxDist = document.getElementById('chartDistEsiti');
    const emptyStateDist = document.getElementById('chartDistEsitiEmpty');
    const totaleLabelDist = document.getElementById('chartDistEsitiTotale');
    const statsPerTipo = @Html.Raw(Json.Serialize(Model.StatistichePerTipo));

    if (ctxDist) {
        let chartDist;

        function getField(obj, name) {
            const key = Object.keys(obj).find(k => k.toLowerCase() === name.toLowerCase());
            return key ? Number(obj[key]) || 0 : 0;
        }

        function getFieldRaw(obj, name) {
    const key = Object.keys(obj).find(k => k.toLowerCase() === name.toLowerCase());
    return key ? obj[key] : null;
}

        function showEmpty(show) {
            ctxDist.style.display = show ? 'none' : 'block';
            emptyStateDist.style.display = show ? 'flex' : 'none';
        }

        function renderChart(tipo) {
          
          if (!tipo) {
        showEmpty(true);
        totaleLabelDist.textContent = '';
        return;
    }
    
    const data = statsPerTipo.find(x => {
        const tipoVal = getFieldRaw(x, 'tipo');
        return tipoVal && tipoVal.trim().toLowerCase() === tipo.trim().toLowerCase();
    });

    if (chartDist) {
        chartDist.destroy();
        chartDist = null;
    }

    if (!data) {
        showEmpty(true);
        totaleLabelDist.textContent = '';
        return;
    }

    const values = [
        getField(data, 'positivi'),
        getField(data, 'negativi'),
        getField(data, 'positivoConRiserva'),
        getField(data, 'inCorso')
    ];
    const totale = values.reduce((a, b) => a + b, 0);

    if (totale === 0) {
        showEmpty(true);
        totaleLabelDist.textContent = '';
        return;
    }

    showEmpty(false);
    totaleLabelDist.textContent = `${totale} verific${totale === 1 ? 'a' : 'he'} totali`;

    chartDist = new Chart(ctxDist, {
        type: 'doughnut',
        data: {
            labels: ['Positivi', 'Negativi', 'Positivi con riserva', 'In Corso'],
            datasets: [{
                data: values,
                backgroundColor: [PALETTE.Positivi, PALETTE.Negativi, PALETTE.Riserva, PALETTE.InCorso],
                borderWidth: 3,
                borderColor: '#fff'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '62%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { usePointStyle: true, font: { size: 11 } }
                },
                tooltip: {
                    callbacks: {
                        label: function (ctx) {
                            const val = ctx.parsed;
                            const pct = totale > 0 ? ((val / totale) * 100).toFixed(1) : 0;
                            return `${ctx.label}: ${val} (${pct}%)`;
                        }
                    }
                }
            }
        }
    });
}

        window.renderChart = renderChart;
        if (statsPerTipo.length > 0) {
           window.renderChart(getFieldRaw(statsPerTipo[0], 'tipo'));
        }
    }

    window.changeTipo = function (tipo) {
        window.renderChart(tipo);
    };
    </text>
}

function toggleFormFigura() {
    const f = document.getElementById('formFigura');
    if (f) f.style.display = f.style.display === 'none' ? 'block' : 'none';
}


function changeAnno(anno) {
    const url = new URL(window.location.href);
    url.searchParams.set('anno', anno);
    window.location.href = url.toString();
}
</script>





<script>
function toggleCategoria(id) {
    const el = document.getElementById(id);
    const icon = document.getElementById("icon-" + id);

    if (!el) return;

    // controllo semplice e sicuro
    if (el.style.display === "none") {
        el.style.display = "block";

        if (icon) {
            icon.classList.remove("bi-chevron-right");
            icon.classList.add("bi-chevron-down");
        }

    } else {
        el.style.display = "none";

        if (icon) {
            icon.classList.remove("bi-chevron-down");
            icon.classList.add("bi-chevron-right");
        }
    }
}
</script>
<style>
.collapsed {
    display: none !important;
}
</style>


}