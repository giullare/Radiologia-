</div>

@section Scripts {
<script>
// ─── TAB SWITCH ──────────────────────────────────────────────────
function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach(b =>
        b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p =>
        p.classList.remove('active'));

    document.querySelector(`#tab-${name}`)?.classList.add('active');
    event.currentTarget.classList.add('active');

    history.replaceState(null, '',
        `?tab=${name}`);
}

// ─── GRAFICI STATISTICHE ─────────────────────────────────────────
@if (Model.VerificheCQ.Any())
{
    var anni = Model.VerificheCQ
        .Where(v => v.Anno.HasValue)
        .GroupBy(v => v.Anno!.Value)
        .OrderBy(g => g.Key)
        .ToList();

    <text>
    // Grafico esiti per anno
    const ctxAnno = document.getElementById('chartEsitiAnno');
    if (ctxAnno) {
        new Chart(ctxAnno, {
            type: 'bar',
            data: {
                labels: [@Html.Raw(string.Join(",",
                    anni.Select(g => $"'{g.Key}'")))],
                datasets: [
                    {
                        label: 'Superati',
                        data: [@string.Join(",",
                            anni.Select(g => g.Count(v =>
                                v.Esito == RadiologiaAppNew.Enums.EsitoVerifica.Superato)))],
                        backgroundColor: 'rgba(39,174,96,0.8)',
                        borderRadius: 6
                    },
                    {
                        label: 'Non Superati',
                        data: [@string.Join(",",
                            anni.Select(g => g.Count(v =>
                                v.Esito == RadiologiaAppNew.Enums.EsitoVerifica.NonSuperato)))],
                        backgroundColor: 'rgba(192,57,43,0.8)',
                        borderRadius: 6
                    },
                    {
                        label: 'Con Riserva',
                        data: [@string.Join(",",
                            anni.Select(g => g.Count(v =>
                                v.Esito == RadiologiaAppNew.Enums.EsitoVerifica.ConRiserva)))],
                        backgroundColor: 'rgba(243,156,18,0.8)',
                        borderRadius: 6
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { grid: { display: false } },
                    y: { beginAtZero: true, ticks: { stepSize: 1 } }
                },
                plugins: {
                    legend: { position: 'top',
                              labels: { usePointStyle: true,
                                        font: { size: 11 } } }
                }
            }
        });
    }

    // Grafico distribuzione esiti (torta)
    const ctxDist = document.getElementById('chartDistEsiti');
    if (ctxDist) {
        new Chart(ctxDist, {
            type: 'doughnut',
            data: {
                labels: ['Superati', 'Non Superati', 'Con Riserva', 'In Corso'],
                datasets: [{
                    data: [
                        @Model.VerificheCQ.Count(v =>
                            v.Esito == RadiologiaAppNew.Enums.EsitoVerifica.Superato),
                        @Model.VerificheCQ.Count(v =>
                            v.Esito == RadiologiaAppNew.Enums.EsitoVerifica.NonSuperato),
                        @Model.VerificheCQ.Count(v =>
                            v.Esito == RadiologiaAppNew.Enums.EsitoVerifica.ConRiserva),
                        @Model.VerificheCQ.Count(v =>
                            v.Esito == RadiologiaAppNew.Enums.EsitoVerifica.InCorso)
                    ],
                    backgroundColor: [
                        '#27AE60','#C0392B','#F39C12','#64748B'
                    ],
                    borderWidth: 3,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                cutout: '60%',
                plugins: {
                    legend: { position: 'bottom',
                              labels: { usePointStyle: true,
                                        font: { size: 11 } } }
                }
            }
        });
    }
    </text>
}
function toggleFormFigura() {
    const f = document.getElementById('formFigura');
    if (f) f.style.display = f.style.display === 'none' ? 'block' : 'none';
}
</script>
<script>
function toggleCategoria(id) {
    const el = document.getElementById(id);
    const icon = document.getElementById("icon-" + id);

    if (!el) return;

    // controllo semplice e sicuro
    if (el.style.display === "none") {
        el.style.display = "block";

        if (icon) {
            icon.classList.remove("bi-chevron-right");
            icon.classList.add("bi-chevron-down");
        }

    } else {
        el.style.display = "none";

        if (icon) {
            icon.classList.remove("bi-chevron-down");
            icon.classList.add("bi-chevron-right");
        }
    }
}
</script>
<style>
.collapsed {
    display: none !important;
}
</style>


}