<!-- ═══ TAB: COMPLIANCE ══════════════════════════════════════════ -->
<div class="tab-panel @(Model.TabAttiva == "compliance" ? "active" : "")"
     id="tab-compliance">

    <div class="alert-radiologia alert-info mb-4">
        <i class="bi bi-info-circle alert-icon"></i>
        <div>
            Pannello di controllo degli adempimenti normativi per questa apparecchiatura.
            Gli stati vengono aggiornati automaticamente in base ai dati inseriti.
        </div>
    </div>

    <!-- Riepilogo -->
    <div class="kpi-grid mb-4" style="grid-template-columns:repeat(4,1fr)">
        @{
            var cOk      = Model.ItemsCompliance.Count(i => i.Stato == "ok");
            var cWarn    = Model.ItemsCompliance.Count(i => i.Stato == "warning");
            var cDanger  = Model.ItemsCompliance.Count(i => i.Stato == "danger");
            var cMissing = Model.ItemsCompliance.Count(i =>
                i.Stato == "missing" || i.Stato == "todo");
        }
        <div class="kpi-card kpi-success" style="padding:14px 18px;">
            <div class="kpi-content">
                <div class="kpi-number" style="font-size:1.8rem;">@cOk</div>
                <div class="kpi-label">In Regola</div>
            </div>
            <i class="bi bi-check-circle kpi-icon"></i>
        </div>
        <div class="kpi-card kpi-warning" style="padding:14px 18px;">
            <div class="kpi-content">
                <div class="kpi-number" style="font-size:1.8rem;">@cWarn</div>
                <div class="kpi-label">In Scadenza</div>
            </div>
            <i class="bi bi-clock kpi-icon"></i>
        </div>
        <div class="kpi-card kpi-danger" style="padding:14px 18px;">
            <div class="kpi-content">
                <div class="kpi-number" style="font-size:1.8rem;">@cDanger</div>
                <div class="kpi-label">Critici</div>
            </div>
            <i class="bi bi-x-circle kpi-icon"></i>
        </div>
        <div class="kpi-card" style="padding:14px 18px;">
            <div class="kpi-content">
                <div class="kpi-number" style="font-size:1.8rem;">@cMissing</div>
                <div class="kpi-label">Da Completare</div>
            </div>
            <i class="bi bi-dash-circle kpi-icon"></i>
        </div>
    </div>

    <div class="compliance-grid">
        @foreach (var item in Model.ItemsCompliance)
        {
            <div class="compliance-item">
                <div class="compliance-dot @item.Stato"></div>
                <div class="compliance-info">
                    <div class="compliance-label">
                        <i class="bi @item.Icona me-1"></i>
                        @item.Label
                    </div>
                    <div class="compliance-detail">@item.Dettaglio</div>
                </div>
                @{
                    var (badgeClass, badgeLabel) = item.Stato switch
                    {
                        "ok"      => ("badge-ok",      "In Regola"),
                        "warning" => ("badge-warning", "In Scadenza"),
                        "danger"  => ("badge-danger",  "Critico"),
                        "todo"    => ("badge-todo",    "Da Fare"),
                        _         => ("badge-missing", "Mancante")
                    };
                }
                <span class="badge-compliance @badgeClass"
                      style="flex-shrink:0;">
                    @badgeLabel
                </span>
            </div>
        }
    </div>
</div>

<!-- ═══ TAB: VERIFICHE CQ ════════════════════════════════════════ -->
<div class="tab-panel @(Model.TabAttiva == "verifiche" ? "active" : "")"
     id="tab-verifiche">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-700" style="margin:0;">Storico Verifiche</h4>
        <a href="/Verifiche/Create/@app.Id" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle"></i>
            Nuova Verifica
        </a>
    </div>

    @if (!Model.VerificheCQ.Any())
    {
        <div class="empty-state">
            <i class="bi bi-clipboard2 empty-state-icon"></i>
            <div class="empty-state-title">Nessuna verifica registrata</div>
            <p class="empty-state-text">
                Registra la prima verifica di collaudo o controllo di qualità.
            </p>
            <a href="/Verifiche/Create/@app.Id" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i>
                Aggiungi Verifica
            </a>
        </div>
    }
    else
    {
        <div class="card">
            <table class="table-radiologia w-100">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Data Esecuzione</th>
                        <th>Esito</th>
                        <th>Prossima Verifica</th>
                        <th>Note</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
    @foreach (var v in Model.VerificheCQ)
    {
        <tr>
            <td>
                <span class="fw-600" style="font-size:0.85rem;">
                    @v.Tipo
                </span>
                @if (v.Anno.HasValue)
                {
                    <div style="font-size:0.75rem;color:var(--neutral-500);">
                        Anno @v.Anno
                    </div>
                }
            </td>
            <td>
                @v.DataInizio.ToString("dd/MM/yyyy")
                @if (v.DataFine.HasValue)
                {
                    <span style="color:var(--neutral-400);">
                        → @v.DataFine.Value.ToString("dd/MM/yyyy")
                    </span>
                }
            </td>
            <td>
                @{
                    string esitoTabClass;
                    string esitoTabIcon;
                    if (v.Esito == EsitoVerifica.Superato)
                    {
                        esitoTabClass = "badge-ok";
                        esitoTabIcon  = "bi-check-circle";
                    }
                    else if (v.Esito == EsitoVerifica.NonSuperato)
                    {
                        esitoTabClass = "badge-danger";
                        esitoTabIcon  = "bi-x-circle";
                    }
                    else if (v.Esito == EsitoVerifica.ConRiserva)
                    {
                        esitoTabClass = "badge-warning";
                        esitoTabIcon  = "bi-exclamation-circle";
                    }
                    else
                    {
                        esitoTabClass = "badge-missing";
                        esitoTabIcon  = "bi-clock";
                    }
                }
                <span class="badge-compliance @esitoTabClass">
                    <i class="bi @esitoTabIcon"></i>
                    @v.Esito
                </span>
            </td>
            <td>
                @if (v.ProssimaVerificaData.HasValue)
                {
                    var gg = (v.ProssimaVerificaData.Value.Date
                              - DateTime.Today).Days;
                    <span style="color:@(gg < 0 ? "var(--danger)"
                                        : gg <= 30 ? "var(--warning)"
                                        : "inherit");">
                        @v.ProssimaVerificaData.Value.ToString("dd/MM/yyyy")
                    </span>
                }
                else
                {
                    <span style="color:var(--neutral-400);">—</span>
                }
            </td>
            <td>
                <span style="font-size:0.8rem;color:var(--neutral-500);">
                    @(v.Note?.Length > 60
                        ? v.Note[..60] + "..."
                        : v.Note ?? "—")
                </span>
            </td>
            <td>
    <div class="d-flex gap-1">

        <!-- Visualizza -->
        <a href="/Verifiche/Detail/@v.Id"
           class="btn btn-ghost btn-icon btn-sm"
           title="Visualizza">
            <i class="bi bi-eye"></i>
        </a>

        <!-- Modifica -->
        <a href="/Verifiche/Edit/@v.Id"
           class="btn btn-ghost btn-icon btn-sm"
           title="Modifica">
            <i class="bi bi-pencil"></i>
        </a>
        <form method="post"
      action="/Verifiche/Delete/@v.Id"
      style="display:inline">
    @Html.AntiForgeryToken()
    <button type="submit"
            class="btn btn-ghost btn-icon btn-sm"
            title="Elimina"
            onclick="return confirm('Eliminare questa verifica?')">
        <i class="bi bi-trash text-danger"></i>
    </button>
</form>

    </div>
</td>
        </tr>
    }
</tbody>
            </table>
        </div>
    }
</div>

