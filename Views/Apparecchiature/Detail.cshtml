                        <canvas id="chartEsitiAnno"
                                style="height:220px;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="bi bi-pie-chart card-icon"></i>
                            Distribuzione Esiti
                        </h3>
                    </div>
                    <div class="card-body d-flex align-items-center
                                justify-content-center">
