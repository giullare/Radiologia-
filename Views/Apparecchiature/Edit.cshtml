        </div>
        <div class="d-flex justify-content-between mt-3">
            <button type="button" class="btn btn-ghost" onclick="vaiStep(4)">
                <i class="bi bi-arrow-left"></i> Indietro
            </button>
            <button type="button" class="btn btn-primary" onclick="vaiStep(6)">
                Avanti — Riepilogo <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>
    <!-- ══ STEP 6 — Riepilogo ════════════════════════════════════ -->
    <div class="wizard-panel" id="panel-6">
        <div class="alert-radiologia alert-info mb-4">
            <i class="bi bi-info-circle alert-icon"></i>
            <div>Verifica le modifiche prima di salvare.</div>
        </div>
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-clipboard-check card-icon"></i>
                    Riepilogo Modifiche
                </h3>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="form-label" style="font-size:0.78rem;color:var(--neutral-500);text-transform:uppercase">Codice</div>
                        <div class="fw-700" id="riepilogo-codice">@Model.Codice</div>
                    </div>
                    <div class="col-md-9">
                        <div class="form-label" style="font-size:0.78rem;color:var(--neutral-500);text-transform:uppercase">Descrizione</div>
                        <div class="fw-700" id="riepilogo-descrizione">@Model.Descrizione</div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-label" style="font-size:0.78rem;color:var(--neutral-500);text-transform:uppercase">Costruttore</div>
                        <div id="riepilogo-costruttore">@Model.Costruttore</div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-label" style="font-size:0.78rem;color:var(--neutral-500);text-transform:uppercase">Modello</div>
                        <div id="riepilogo-modello">@Model.Modello</div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-label" style="font-size:0.78rem;color:var(--neutral-500);text-transform:uppercase">Tipologia</div>
                        <div id="riepilogo-tipologia">@Model.Tipologia</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-3">
            <button type="button" class="btn btn-ghost" onclick="vaiStep(5)">
                <i class="bi bi-arrow-left"></i> Indietro
            </button>
        </div>
    </div>
</form>
@section Scripts {
<script>
let stepCorrente = 1;
window.addEventListener('DOMContentLoaded', () => {
    const stepIniziale = @(ViewBag.StepIniziale ?? 1);
    if (stepIniziale && stepIniziale !== 1) {
        vaiStep(stepIniziale);
    }
});
function vaiStep(n) {
    document.querySelectorAll('.wizard-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.wizard-step').forEach((s, i) => {
        s.classList.remove('active', 'complete');
        if (i + 1 < n)  s.classList.add('complete');
        if (i + 1 === n) s.classList.add('active');
    });
    document.getElementById(`panel-${n}`)?.classList.add('active');
    stepCorrente = n;
    window.scrollTo({ top: 0, behavior: 'smooth' });
    if (n === 6) aggiornaRiepilogo();
}
function aggiornaRiepilogo() {
    const get  = id => document.getElementById(id)?.value || '—';
    const getT = id => {
        const s = document.getElementById(id);
        return s?.options[s.selectedIndex]?.text || '—';
    };
    const setR = (id, val) => {
        const el = document.getElementById(id);
        if (el) el.textContent = val || '—';
    };
    setR('riepilogo-codice',       get('Codice'));
    setR('riepilogo-descrizione',  get('Descrizione'));
    setR('riepilogo-costruttore',  getT('selectCostruttore'));
    setR('riepilogo-modello',      getT('selectModello'));
    setR('riepilogo-tipologia',    getT('selectTipologia'));
}
async function onAmbitoChange() {
    const ambito  = document.getElementById('selectAmbito')?.value;
    const selTipo = document.getElementById('selectTipologia');
    selTipo.innerHTML = '<option value="">— Seleziona tipologia —</option>';
    if (!ambito) return;
    try {
        const res  = await fetch(`/Apparecchiature/GetTipologiePerAmbito?ambito=${ambito}`);
        const data = await res.json();
        data.forEach(t => selTipo.add(new Option(t, t)));
    } catch {}
}
async function caricaImmobili(sitoId) {
document.getElementById('hiddenSitoId').value = sitoId;
    // reset livelli sotto
    document.getElementById('hiddenImmobileId').value = '';
    document.getElementById('hiddenPianoId').value = '';
    document.getElementById('hiddenLocaleId').value = '';
const sel = document.getElementById('selectImmobile');
    resetSelect(sel, '— Prima seleziona Edificio —');
    resetSelect(document.getElementById('selectPiano'), '— Prima seleziona Piano —');
    resetSelect(document.getElementById('selectLocale'), '— Prima seleziona Locale —');
    if (!sitoId) return;
    try {
        const res  = await fetch(`/Apparecchiature/GetImmobiliPerSito?sitoId=${sitoId}`);
        const data = await res.json();
        sel.innerHTML = '<option value="">— Seleziona edificio —</option>';
        data.forEach(i => sel.add(new Option(i.nome, i.id)));
        //sel.disabled = false;
    sel.style.pointerEvents = 'auto';
    sel.style.backgroundColor = '';
    } catch {}
}
async function caricaPiani(immobileId) {
document.getElementById('hiddenImmobileId').value = immobileId;
    document.getElementById('hiddenPianoId').value = '';
    document.getElementById('hiddenLocaleId').value = '';
const sel = document.getElementById('selectPiano');
    resetSelect(sel, '— Prima seleziona Piano —');
    resetSelect(document.getElementById('selectLocale'), '— Prima seleziona Locale —');
    if (!immobileId) return;
    try {
        const res  = await fetch(`/Apparecchiature/GetPianiPerImmobile?immobileId=${immobileId}`);
        const data = await res.json();
        sel.innerHTML = '<option value="">— Seleziona piano —</option>';
        data.forEach(p => sel.add(new Option(p.nome, p.id)));
        //sel.disabled = false;
 sel.style.pointerEvents = 'auto';
    sel.style.backgroundColor = '';
    } catch {}
}
async function caricaLocali(pianoId) {
    document.getElementById('hiddenPianoId').value = pianoId;
    const sel = document.getElementById('selectLocale');
    const hidden = document.getElementById('hiddenLocaleId'); // ✅ MANCAVA
    resetSelect(sel, '— Prima seleziona Locale —');
    if (!pianoId) return;
    try {
        const res  = await fetch(`/Apparecchiature/GetLocaliPerPiano?pianoId=${pianoId}`);
        const data = await res.json();
        sel.innerHTML = '<option value="">— Seleziona locale —</option>';
        data.forEach(l => sel.add(new Option(l.nome, l.id)));
 sel.style.pointerEvents = 'auto';
    sel.style.backgroundColor = '';
sel.onchange = () => hidden.value = sel.value;
    } catch {}
}
//function resetSelect(sel, placeholder) {
    //if (!sel) return;
    //sel.innerHTML = `<option value="">${placeholder}</option>`;
    //sel.disabled  = true;
//}
function resetSelect(sel, placeholder) {
    if (!sel) return;
    sel.innerHTML = `<option value="">${placeholder}</option>`;
    sel.style.pointerEvents = 'none';
    sel.style.backgroundColor = '#e9ecef';
}
async function onCostruttoreChange() {
    const sel  = document.getElementById('selectCostruttore');
    const selM = document.getElementById('selectModello');
    const opt  = sel?.options[sel.selectedIndex];
    const cId  = opt?.getAttribute('data-id');
    if (cId && selM) {
        selM.innerHTML = '<option value="">Caricamento...</option>';
        try {
            const res  = await fetch(`/Apparecchiature/GetModelliPerCostruttore?costruttoreId=${cId}`);
            const data = await res.json();
            selM.innerHTML = '<option value="">— Seleziona modello —</option>';
            data.forEach(m => selM.add(new Option(m.nome, m.nome)));
            // Ripristina valore corrente
            selM.value = '@Model.Modello';
        } catch {}
    }
}
window.addEventListener('DOMContentLoaded', async () => {
    const ambito = '@(Model.AmbitoIntervento?.ToString() ?? "")';
    const tipo   = '@(Model.Tipologia ?? "")';
    if (!ambito) return;
    const sel = document.getElementById('selectTipologia');
    try {
        const res  = await fetch(`/Apparecchiature/GetTipologiePerAmbito?ambito=${ambito}`);
        const data = await res.json();
        sel.innerHTML = '<option value="">— Seleziona tipologia —</option>';
        data.forEach(t => sel.add(new Option(t, t)));
        if (tipo) sel.value = tipo;
    } catch {}
});
</script>
<script>
document.getElementById('selectSito').addEventListener('change', e => {
    hiddenSitoId.value = e.target.value;
    caricaImmobili(e.target.value);
});
document.getElementById('selectImmobile').addEventListener('change', e => {
    hiddenImmobileId.value = e.target.value;
    caricaPiani(e.target.value);
});
document.getElementById('selectPiano').addEventListener('change', e => {
    hiddenPianoId.value = e.target.value;
    caricaLocali(e.target.value);
});
document.getElementById('selectLocale').addEventListener('change', e => {
    hiddenLocaleId.value = e.target.value;
});
window.addEventListener('DOMContentLoaded', async () => {
    const sitoId     = '@Model.SitoId';
    const immobileId = '@Model.ImmobileId';
    const pianoId    = '@Model.PianoId';
    const localeId   = '@Model.LocaleId';
    if (sitoId) {
        document.getElementById('selectSito').value = sitoId;
        await caricaImmobili(sitoId);
    }
    if (immobileId) {
        document.getElementById('selectImmobile').value = immobileId;
        await caricaPiani(immobileId);
    }
    if (pianoId) {
        document.getElementById('selectPiano').value = pianoId;
        await caricaLocali(pianoId);
    }
    if (localeId) {
        document.getElementById('selectLocale').value = localeId;
        document.getElementById('hiddenLocaleId').value = localeId;
    }
});
</script>
<style>
.step-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    cursor: pointer;
}
</style>
}