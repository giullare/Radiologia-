                                <label class="form-label">Ricevuta Registrazione INAIL</label>
                                @if (!string.IsNullOrEmpty(Model.InailRicevutaRegistrazioneFile))
                                {
                                    <div class="mb-1 d-flex align-items-center gap-2">
                                        <a href="@Model.InailRicevutaRegistrazioneFile"
                                           target="_blank" class="btn btn-ghost btn-sm">
                                            <i class="bi bi-file-earmark"></i>
                                            @(string.IsNullOrEmpty(Model.InailRicevutaRegistrazioneNomeOriginale)
                                                ? "File attuale"
                                                : Model.InailRicevutaRegistrazioneNomeOriginale)
                                        </a>
                                        <button type="submit"
                                                formaction="/Apparecchiature/EliminaFile?id=@Model.Id&amp;campo=InailRicevutaRegistrazioneFile"
                                                formmethod="post"
                                                class="btn btn-outline-danger btn-sm"
                                                title="Elimina definitivamente il file"
                                                onclick="return confirm('Eliminare definitivamente questo file? L\'operazione non è reversibile.');">
                                            <i class="bi bi-x-lg"></i>
