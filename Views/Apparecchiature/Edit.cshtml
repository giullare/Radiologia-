@model RadiologiaAppNew.Models.Apparecchiatura
@using RadiologiaAppNew.Enums
@{
    Layout = "_Layout";
    ViewData["Title"] = $"Modifica — {Model.Descrizione}";
    ViewData["BreadcrumbParent"] = "Inventario";
    ViewData["BreadcrumbParentUrl"] = "/Apparecchiature";
}
<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-pencil me-2 text-primary"></i>
            Modifica Apparecchiatura
        </h1>
        <p class="page-subtitle">@Model.Codice — @Model.Descrizione</p>
    </div>
    <div class="page-actions">
        <a href="/Apparecchiature/Detail/@Model.Id" class="btn btn-ghost">
            <i class="bi bi-arrow-left"></i> Torna alla scheda
        </a>
        <button type="submit" form="formEdit" class="btn btn-secondary"
                onclick="preparaSubmit()">
            <i class="bi bi-check-circle"></i> Salva Modifiche
        </button>
        <a href="/Apparecchiature/Stampa/@Model.Id" target="_blank"
           class="btn btn-ghost">
            <i class="bi bi-printer"></i> Stampa
        </a>
    </div>
</div>
<!-- ═══ WIZARD STEPS — cliccabili ════════════════════════════════ -->
<div class="wizard-steps mb-4">
    @foreach (var (num, lbl) in new[] {
        (1,"Dati Base"), (2,"Parametri Tecnici"),
        (3,"Collocazione / Responsabili"), (4,"Assistenza"),
        (5,"Tracciabilità e Denuncia"), (6,"Riepilogo") })
    {
        <div class="wizard-step @(num == 1 ? "active" : "")" id="step-ind-@num">
            <a href="#" onclick="vaiStep(@num);return false;" class="step-link">
                <div class="step-circle">@num</div>
                <div class="step-label">@lbl</div>
            </a>
        </div>
    }
</div>
<!-- ═══ FORM ══════════════════════════════════════════════════════ -->
<form asp-action="Edit" asp-controller="Apparecchiature"
      asp-route-id="@Model.Id"
      method="post" id="formEdit"
      enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Modulo" value="Radiologica" />
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-radiologia alert-danger mb-4">
            <i class="bi bi-exclamation-circle alert-icon"></i>
            <div>
                <strong>Correggi i seguenti errori:</strong>
                <ul style="margin:6px 0 0;padding-left:16px;">
                    @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li style="font-size:0.85rem;">@e.ErrorMessage</li>
                    }
                </ul>
            </div>
        </div>
    }
    <!-- ══ STEP 1 — Dati Base ════════════════════════════════════ -->
    <div class="wizard-panel active" id="panel-1">
        <div class="form-section">
            <div class="form-section-header">
                <i class="bi bi-card-list text-primary"></i>
                <h4 class="form-section-title">Dati Identificativi</h4>
            </div>
            <div class="form-section-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Codice" class="form-label"></label>
                        <input asp-for="Codice" class="form-control" />
                        <span asp-validation-for="Codice" class="text-danger"
                              style="font-size:0.775rem"></span>
                    </div>
                    <div class="col-md-8">
                        <label asp-for="Descrizione" class="form-label"></label>
                        <input asp-for="Descrizione" class="form-control" />
                        <span asp-validation-for="Descrizione" class="text-danger"
                              style="font-size:0.775rem"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="AmbitoIntervento" class="form-label">Ambito</label>
                        <select asp-for="AmbitoIntervento" class="form-select"
                                id="selectAmbito" onchange="onAmbitoChange()">
                            <option value="">— Seleziona —</option>
                            <option value="@AmbitoIntervento.Radiologia.ToString()"
            selected="@(Model.AmbitoIntervento == AmbitoIntervento.Radiologia ? "selected" : null)">
        Radiologia
    </option>
    <option value="@AmbitoIntervento.RadiologiaInterventistica.ToString()"
            selected="@(Model.AmbitoIntervento == AmbitoIntervento.RadiologiaInterventistica ? "selected" : null)">
        Radiologia Interventistica
    </option>
    <option value="@AmbitoIntervento.MedicinaNucleare.ToString()"
            selected="@(Model.AmbitoIntervento == AmbitoIntervento.MedicinaNucleare ? "selected" : null)">
        Medicina Nucleare
    </option>
    <option value="@AmbitoIntervento.Radioterapia.ToString()"
            selected="@(Model.AmbitoIntervento == AmbitoIntervento.Radioterapia ? "selected" : null)">
        Radioterapia
    </option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Tipologia" class="form-label"></label>
                        <select asp-for="Tipologia" class="form-select" id="selectTipologia">
                            <option value="@Model.Tipologia">@Model.Tipologia</option>
                        </select>
                        <span asp-validation-for="Tipologia" class="text-danger"
                              style="font-size:0.775rem"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Costruttore / Produttore</label>
                        <select name="Costruttore" class="form-select"
                                id="selectCostruttore" onchange="onCostruttoreChange()">
                            <option value="">— Seleziona —</option>
                            @if (ViewBag.Costruttori != null)
                            {
                                foreach (var c in (List<RadiologiaAppNew.Models.Costruttore>)ViewBag.Costruttori)
                                {
                                    <option value="@c.Nome" data-id="@c.Id"
                selected="@(Model.Costruttore == c.Nome ? "selected" : null)">
            @c.Nome
        </option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Modello</label>
                        <select name="Modello" class="form-select" id="selectModello">
                            <option value="@Model.Modello" selected>@Model.Modello</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Matricola" class="form-label"></label>
                        <input asp-for="Matricola" class="form-control" />
                        <span asp-validation-for="Matricola" class="text-danger"
                              style="font-size:0.775rem"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SerialNumber" class="form-label"></label>
                        <input asp-for="SerialNumber" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Stato" class="form-label"></label>
                        <select asp-for="Stato" class="form-select">
                            <option value="InInstallazione">In Installazione</option>
                            <option value="Attiva">Attiva</option>
                            <option value="InManutenzione">In Manutenzione</option>
                            <option value="Cessata">Cessata</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DataAccettazione" class="form-label"></label>
                        <input asp-for="DataAccettazione" type="date" class="form-control" />
                    </div>
<div class="col-12"></div>
                     <div class="col-md-4">
                        <label asp-for="SapId" class="form-label"></label>
                        <input asp-for="SapId" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SiapDescrizione" class="form-label"></label>
                        <input asp-for="SiapDescrizione" class="form-control" />
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-end mt-3">
            <button type="button" class="btn btn-primary" onclick="vaiStep(2)">
                Avanti <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>
    <!-- ══ STEP 2 — Parametri Tecnici ════════════════════════════ -->
    <div class="wizard-panel" id="panel-2">
        <div class="form-section">
            <div class="form-section-header">
                <i class="bi bi-lightning-charge text-primary"></i>
                <h4 class="form-section-title">Parametri Radiologici</h4>
            </div>
            <div class="form-section-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="CorrenteMaxMa" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="CorrenteMaxMa" type="number" step="0.1"
                                   class="form-control" />
                            <span class="input-group-text"
                                  style="border:1.5px solid var(--neutral-200);
                                         border-left:none;background:var(--neutral-50);
                                         font-size:0.85rem;">mA</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="TensioneMaxKvolt" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="TensioneMaxKvolt" type="number" step="0.1"
                                   class="form-control" />
                            <span class="input-group-text"
                                  style="border:1.5px solid var(--neutral-200);
                                         border-left:none;background:var(--neutral-50);
                                         font-size:0.85rem;">kV</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EnergiaMaxKev" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="EnergiaMaxKev" type="number" step="0.1"
                                   class="form-control" />
                            <span class="input-group-text"
                                  style="border:1.5px solid var(--neutral-200);
                                         border-left:none;background:var(--neutral-50);
                                         font-size:0.85rem;">keV</span>
                        </div>
                    </div>
                    <div class="col-12"><hr class="divider" /></div>
                    <div class="col-md-4">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="LanCollegata" class="form-check-input"
                                   type="checkbox" style="width:2.5em;height:1.3em;" />
                            <label asp-for="LanCollegata" class="form-check-label ms-2">
                                Collegata in Rete (LAN)
                            </label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="MedsquareInstallato" class="form-check-input"
                                   type="checkbox" style="width:2.5em;height:1.3em;" />
                            <label asp-for="MedsquareInstallato" class="form-check-label ms-2">
                                Software di monitoraggio dose installato
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-3">
            <button type="button" class="btn btn-ghost" onclick="vaiStep(1)">
                <i class="bi bi-arrow-left"></i> Indietro
            </button>
            <button type="button" class="btn btn-primary" onclick="vaiStep(3)">
                Avanti <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>
    <!-- ══ STEP 3 — Collocazione / Responsabili ══════════════════ -->
    <div class="wizard-panel" id="panel-3">
        <div class="form-section mb-4">
            <div class="form-section-header">
                <i class="bi bi-geo-alt text-primary"></i>
                <h4 class="form-section-title">Collocazione Fisica</h4>
            </div>
            <div class="form-section-body">
                <div class="row g-3">
 <div class="col-12">
                        <p style="font-size:0.85rem;color:var(--neutral-500);margin-bottom:12px;">
                            <i class="bi bi-info-circle me-1"></i>
                            Seleziona la posizione esatta (Sito → Edificio → Piano → Locale)
                        </p>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Sito / Presidio</label>
                        <select class="form-select" id="selectSito"
                                asp-items="ViewBag.Siti">
                            <option value="">— Seleziona —</option>
                        </select>
                        <input type="hidden" asp-for="SitoId" id="hiddenSitoId" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Edificio</label>
                        <select class="form-select" id="selectImmobile"
                                style="pointer-events:none; background-color:#e9ecef;">
                            <option value="">— Prima seleziona Sito —</option>
                        </select>
                       <input type="hidden" asp-for="ImmobileId" id="hiddenImmobileId" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Piano</label>
                        <select class="form-select" id="selectPiano"
                                style="pointer-events:none; background-color:#e9ecef;">
                            <option value="">— Prima seleziona Edificio —</option>
                        </select>
                       <input type="hidden" asp-for="PianoId" id="hiddenPianoId" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Locale / Stanza</label>
                        <select  class="form-select"
                                id="selectLocale"
                                style="pointer-events:none; background-color:#e9ecef;">
                            <option value="">— Prima seleziona Piano —</option>
                        </select>
                       <input type="hidden" asp-for="LocaleId" id="hiddenLocaleId" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Struttura</label>
                        <select asp-for="RepartoId" class="form-select"
                                asp-items="ViewBag.Reparti">
                            <option value="">— Seleziona struttura —</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Dipartimento</label>
                        <select asp-for="DipartimentoId" class="form-select"
                                asp-items="ViewBag.Dipartimenti">
                            <option value="">— Seleziona dipartimento —</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label asp-for="DescrizioneZoneClassificate" class="form-label"></label>
                        <textarea asp-for="DescrizioneZoneClassificate"
                                  class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Piantina Zone Classificate</label>
                        @if (!string.IsNullOrEmpty(Model.PiantinaZoneClassificateFile))
                        {
                            <div class="mb-2 d-flex align-items-center gap-2">
                                <a href="@Model.PiantinaZoneClassificateFile"
                                   target="_blank" class="btn btn-ghost btn-sm">
                                    <i class="bi bi-file-earmark-image"></i>
                                    @(string.IsNullOrEmpty(Model.PiantinaZoneClassificateNomeOriginale)
                                        ? "File attuale — clicca per vedere"
                                        : Model.PiantinaZoneClassificateNomeOriginale)
                                </a>
                                <button type="submit"
                                        formaction="/Apparecchiature/EliminaFile?id=@Model.Id&amp;campo=PiantinaZoneClassificateFile"
                                        formmethod="post"
                                        class="btn btn-outline-danger btn-sm"
                                        title="Elimina definitivamente il file"
                                        onclick="return confirm('Eliminare definitivamente questo file? L\'operazione non è reversibile.');">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                        <input type="file" name="filePiantina" class="form-control"
                               accept=".pdf,.jpg,.jpeg,.png,.tiff" />
                        <div class="form-text">
                            Lascia vuoto per mantenere il file esistente
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Responsabili -->
        <div class="form-section">
            <div class="form-section-header">
                <i class="bi bi-people text-primary"></i>
                <h4 class="form-section-title">Responsabili</h4>
            </div>
            <div class="form-section-body">
                @{
                    void RespRow(string label,
                                 string nomeField,  string? nomeVal,
                                 string emailField, string? emailVal,
                                 string pecField,   string? pecVal,
                                 string telField,   string? telVal)
                    {
                        <div class="row g-2 mb-3 p-3 rounded-3"
                             style="background:var(--neutral-50);
                                    border:1px solid var(--neutral-200)">
                            <div class="col-12">
                                <div class="fw-600" style="font-size:0.82rem;
                                     color:var(--primary);margin-bottom:6px">
                                    <i class="bi bi-person-badge me-1"></i>@label
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label" style="font-size:0.8rem">Nome e Cognome</label>
                                <input type="text" name="@nomeField" class="form-control"
                                       value="@nomeVal" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label" style="font-size:0.8rem">Email</label>
                                <input type="email" name="@emailField" class="form-control"
                                       value="@emailVal" placeholder="email@esempio.it" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label" style="font-size:0.8rem">PEC</label>
                                <input type="email" name="@pecField" class="form-control"
                                       value="@pecVal" placeholder="pec@esempio.it" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label" style="font-size:0.8rem">Telefono</label>
                                <input type="text" name="@telField" class="form-control"
                                       value="@telVal" />
                            </div>
                        </div>
                    }
                }
                @{ RespRow("Direttore Dipartimento",
                       "DirettoreDipartimento",         Model.DirettoreDipartimento,
                       "DirettoreDipartimentoEmail",    Model.DirettoreDipartimentoEmail,
                       "DirettoreDipartimentoEmailPec", Model.DirettoreDipartimentoEmailPec,
                       "DirettoreDipartimentoTelefono", Model.DirettoreDipartimentoTelefono); }
                @{ RespRow("Direttore Struttura",
                       "DirettoreStruttura",         Model.DirettoreStruttura,
                       "DirettoreStrutturaEmail",    Model.DirettoreStrutturaEmail,
                       "DirettoreStrutturaEmailPec", Model.DirettoreStrutturaEmailPec,
                       "DirettoreStrutturaTelefono", Model.DirettoreStrutturaTelefono); }
                @{ RespRow("Preposto D. Lgs 101/20",
                       "Caposala",        Model.Caposala,
                       "PrepostoEmail",   Model.PrepostoEmail,
                       "PrepostoEmailPec",Model.PrepostoEmailPec,
                       "PrepostoTelefono",Model.PrepostoTelefono); }
                @{ RespRow("Responsabile Impianto Radiologico (RIR)",
                       "RirNome",    Model.RirNome,
                       "RirEmail",   Model.RirEmail,
                       "RirEmailPec",Model.RirEmailPec,
                       "RirTelefono",Model.RirTelefono); }
                @{ RespRow("Specialista in Fisica Medica (SFM)",
                       "SfmNome",    Model.SfmNome,
                       "SfmEmail",   Model.SfmEmail,
                       "SfmEmailPec",Model.SfmEmailPec,
                       "SfmTelefono",Model.SfmTelefono); }
                @{ RespRow("Esperto di Radioprotezione (EdR)",
                       "EdrNome",    Model.EdrNome,
                       "EdrEmail",   Model.EdrEmail,
                       "EdrEmailPec",Model.EdrEmailPec,
                       "EdrTelefono",Model.EdrTelefono); }
            </div>
        </div>
        <div class="d-flex justify-content-between mt-3">
            <button type="button" class="btn btn-ghost" onclick="vaiStep(2)">
                <i class="bi bi-arrow-left"></i> Indietro
            </button>
            <button type="button" class="btn btn-primary" onclick="vaiStep(4)">
                Avanti <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>
    <!-- ══ STEP 4 — Assistenza ════════════════════════════════════ -->
    <div class="wizard-panel" id="panel-4">
        <div class="form-section">
            <div class="form-section-header">
                <i class="bi bi-wrench-adjustable text-primary"></i>
                <h4 class="form-section-title">Riferimenti Assistenza e Manutenzione</h4>
            </div>
            <div class="form-section-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="SocietaManutenzione" class="form-label"></label>
                        <input asp-for="SocietaManutenzione" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="TecnicoRiferimento" class="form-label"></label>
                        <input asp-for="TecnicoRiferimento" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NumeroAssistenza" class="form-label"></label>
                        <input asp-for="NumeroAssistenza" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="GlobalService" class="form-label"></label>
                        <input asp-for="GlobalService" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EmailAssistenza" class="form-label"></label>
                        <input asp-for="EmailAssistenza" type="email" class="form-control" />
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-3">
            <button type="button" class="btn btn-ghost" onclick="vaiStep(3)">
                <i class="bi bi-arrow-left"></i> Indietro
            </button>
            <button type="button" class="btn btn-primary" onclick="vaiStep(5)">
                Avanti <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>
    <!-- ══ STEP 5 — Tracciabilità ════════════════════════════════ -->
    <div class="wizard-panel" id="panel-5">
        <div class="row g-4">
            <!-- STRIMS -->
            <div class="col-md-6">
                <div class="form-section h-100">
                    <div class="form-section-header">
                        <i class="bi bi-database-check text-primary"></i>
                        <h4 class="form-section-title">Registrazione STRIMS</h4>
                    </div>
                    <div class="form-section-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="StatoStrims" class="form-label"></label>
                                <select asp-for="StatoStrims" class="form-select">
                                    <option value="DaRegistrare">Da Registrare</option>
                                    <option value="Registrato">Già Registrato</option>
                                    <option value="NonApplicabile">Non Applicabile</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label asp-for="StrimsIdApparecchiatura" class="form-label"></label>
                                <input asp-for="StrimsIdApparecchiatura" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label asp-for="DataRegistrazioneStrims" class="form-label"></label>
                                <input asp-for="DataRegistrazioneStrims" type="date"
                                       class="form-control" />
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input asp-for="StrimsNpCaricata" type="checkbox"
                                           class="form-check-input" />
                                    <label asp-for="StrimsNpCaricata" class="form-check-label"
                                           style="font-size:0.875rem;">
                                        Notifica di Pratica caricata
                                    </label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Ricevuta Registrazione STRIMS</label>
                                @if (!string.IsNullOrEmpty(Model.StrimsRicevutaRegistrazioneFile))
                                {
                                    <div class="mb-1 d-flex align-items-center gap-2">
                                        <a href="@Model.StrimsRicevutaRegistrazioneFile"
                                           target="_blank" class="btn btn-ghost btn-sm">
                                            <i class="bi bi-file-earmark"></i>
                                            @(string.IsNullOrEmpty(Model.StrimsRicevutaRegistrazioneNomeOriginale)
                                                ? "File attuale"
                                                : Model.StrimsRicevutaRegistrazioneNomeOriginale)
                                        </a>
                                        <button type="submit"
