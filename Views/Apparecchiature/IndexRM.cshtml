@model RadiologiaAppNew.ViewModels.Apparecchiature.ApparecchiaturaListViewModel
@using RadiologiaAppNew.Enums
@{
    Layout = "_Layout";
    ViewData["Title"] = "Apparecchiature RM";
    ViewData["BreadcrumbParent"] = "Apparecchiature a Risonanza Magnetica (DM 14/01/21)";
    var tipologiePerAmbito = ViewBag.TipologiePerAmbito as List<string> ?? new List<string>();
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-hdd-rack me-2 text-primary"></i>
            Apparecchiature RM
        </h1>
        <p class="page-subtitle">
            @Model.TotaleRisultati apparecchiat@(Model.TotaleRisultati == 1 ? "ura" : "ure") trovate
        </p>
    </div>
    <div class="page-actions">
        <a href="/Apparecchiature/CreateRM" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuova
        </a>
        <a href="/Apparecchiature/IndexRM?stato=Cessata" class="btn btn-ghost">
            <i class="bi bi-archive"></i> Cessate
        </a>
        <a href="/Apparecchiature/ExportCsvRM@(string.IsNullOrEmpty(Model.StatoFiltro) ? "" : $"?stato={Model.StatoFiltro}")@(string.IsNullOrEmpty(Model.AmbitoFiltro) ? "" : $"&ambito={Model.AmbitoFiltro}")"
           class="btn btn-ghost">
            <i class="bi bi-download"></i> Export CSV
        </a>
    </div>
</div>

<!-- ═══ FILTRI ════════════════════════════════════════════════════ -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="IndexRM" id="formFiltri">
            <div class="row g-3 align-items-end">

                <div class="col-md-4">
                    <label class="form-label fw-600" style="font-size:0.78rem;
                           text-transform:uppercase;letter-spacing:.04em;
                           color:var(--neutral-500)">CERCA</label>
                    <div class="input-group">
                        <span class="input-group-text"
                              style="background:var(--neutral-50);
                                     border:1.5px solid var(--neutral-200);border-right:none;">
                            <i class="bi bi-search text-muted"
                               style="font-size:0.85rem"></i>
                        </span>
                        <input type="text" name="search"
                               value="@Model.SearchText"
                               class="form-control"
                               style="border-left:none;"
                               placeholder="Codice, descrizione, modello, costruttore..." />
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-600" style="font-size:0.78rem;
                           text-transform:uppercase;letter-spacing:.04em;
                           color:var(--neutral-500)">STATO</label>
                    <select name="stato" class="form-select">
                        <option value="">Tutti</option>
                        @foreach (var s in Enum.GetValues<StatoApparecchiatura>())
                        {
                            <option value="@s"
        selected="@(Model.StatoFiltro == s.ToString())">
    @(s switch {
        StatoApparecchiatura.Attiva => "Attiva",
        StatoApparecchiatura.Cessata => "Cessata",
        StatoApparecchiatura.InInstallazione => "In Installazione",
        StatoApparecchiatura.InManutenzione => "In Manutenzione",
        _ => s.ToString()
    })
</option>
                        }
                    </select>
                </div>


                <div class="col-md-2">
                    <label class="form-label fw-600" style="font-size:0.78rem;
                           text-transform:uppercase;letter-spacing:.04em;
                           color:var(--neutral-500)">TIPOLOGIA RM</label>
                    <select name="tipologia" class="form-select" id="filtroTipologia">
                        <option value="">Tutte</option>
                        @foreach (var t in tipologiePerAmbito)
                        {
                            <option value="@t"
        selected="@(Model.TipologiaFiltro == t)">
    @t
</option>
                        }
                    </select>
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-search"></i> Cerca
                    </button>
                    @if (Model.HaFiltriAttivi)
                    {
                        <a href="/Apparecchiature" class="btn btn-ghost" title="Azzera filtri">
                            <i class="bi bi-x-circle"></i>
                        </a>
                    }
                </div>

            </div>
        </form>
    </div>
</div>

<!-- ═══ TABELLA ═══════════════════════════════════════════════════ -->
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-table card-icon"></i>
            Elenco Apparecchiature
        </h3>
        <span style="font-size:0.8rem;color:var(--neutral-500);margin-left:auto;">
            Pagina @Model.PaginaCorrente di @Model.TotalePagine
        </span>
    </div>

    @if (!Model.Apparecchiature.Any())
    {
        <div class="empty-state" style="padding:60px">
            <i class="bi bi-hdd-rack empty-state-icon"></i>
            <div class="empty-state-title">
                @if (Model.HaFiltriAttivi)
                {
                    <span>Nessuna apparecchiatura trovata con i filtri selezionati</span>
                }
                else
                {
                    <span>Nessuna apparecchiatura registrata</span>
                }
            </div>
            <p class="empty-state-text">
                @if (!Model.HaFiltriAttivi)
                {
                    <span>Inizia aggiungendo la prima apparecchiatura.</span>
                }
            </p>
            <div class="d-flex gap-2 justify-content-center">
                @if (Model.HaFiltriAttivi)
                {
                    <a href="/Apparecchiature" class="btn btn-ghost">
                        <i class="bi bi-x-circle"></i> Azzera filtri
                    </a>
                }
                <a href="/Apparecchiature/CreateRM" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Nuova Apparecchiatura
                </a>
            </div>
        </div>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table class="table-radiologia w-100">
                <thead>
                    <tr>
                        <th style="width:90px">CODICE</th>
                        <th>APPARECCHIATURA</th>
                        <th>TIPOLOGIA</th>
                        <th>STRUTTURA</th>
                        <th>STATO</th>
                        <th>CONTROLLI PERIODICI/MANUTENTIVI</th>
                        <th>PROSSIMO CONTROLLO</th>
                        <th style="width:80px">AZIONI</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Apparecchiature)
                    {
                        var oggi = DateTime.Today;
                        <tr>
                            <!-- Codice -->
                            <td>
                                <span style="display:inline-block;padding:3px 8px;
                                             border-radius:6px;font-weight:700;
                                             font-size:0.78rem;letter-spacing:.03em;
                                             background:@(a.Modulo == TipoModulo.RM
                                                ? "rgba(108,52,131,0.12)"
                                                : "rgba(27,79,114,0.1)");
                                             color:@(a.Modulo == TipoModulo.RM
                                                ? "#6c3483"
                                                : "var(--primary)");">
                                    @a.Codice
                                </span>
                            </td>

                            <!-- Apparecchiatura -->
                            <td>
                                <div class="fw-600" style="font-size:0.875rem">
                                    @a.Descrizione
                                </div>
                                <div style="font-size:0.775rem;color:var(--neutral-400)">
                                    @a.Costruttore — @a.Modello
                                </div>
                            </td>

                            <!-- Tipologia + Ambito -->
                            <td>
                                <div style="font-size:0.85rem">@a.Tipologia</div>
                                @if (a.AmbitoIntervento.HasValue)
                                {
                                    <div style="font-size:0.75rem;color:var(--neutral-400)">
                                        @(a.AmbitoIntervento switch {
                                            AmbitoIntervento.Radiologia => "Radiologia",
                                            AmbitoIntervento.RadiologiaInterventistica => "Interventistica",
                                            AmbitoIntervento.MedicinaNucleare => "Medicina Nucleare",
                                            AmbitoIntervento.Radioterapia => "Radioterapia",
                                            _ => a.AmbitoIntervento.ToString()
                                        })
                                    </div>
                                }
                            </td>

                            <!-- Struttura / Locale -->
                            <td>
                                @if (!string.IsNullOrEmpty(a.Locale))
                                {
                                    <div style="font-size:0.825rem">
                                        <i class="bi bi-geo-alt"
                                           style="font-size:0.75rem;
                                                  color:var(--neutral-400)"></i>
                                        @a.Locale
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(a.Reparto))
                                {
                                    <div style="font-size:0.775rem;color:var(--neutral-400)">
                                        @a.Reparto
                                    </div>
                                }
                            </td>

                            <!-- Stato -->
                            <td>
                                @{
                                    var (statoClass, statoIcon, statoLabel) = a.Stato switch {
                                        StatoApparecchiatura.Attiva =>
                                            ("badge-ok", "bi-check-circle-fill", "Attiva"),
                                        StatoApparecchiatura.InManutenzione =>
                                            ("badge-warning", "bi-tools", "In Manutenzione"),
                                        StatoApparecchiatura.InInstallazione =>
                                            ("badge-todo", "bi-gear", "In Installazione"),
                                        StatoApparecchiatura.Cessata =>
                                            ("badge-missing", "bi-x-circle", "Cessata"),
                                        _ => ("badge-missing", "bi-circle", a.Stato.ToString())
                                    };
                                }
                                <span class="badge-compliance @statoClass">
                                    <i class="bi @statoIcon"></i> @statoLabel
                                </span>
                            </td>

                            <!-- Controlli Periodici/Manutentivi -->
                            <td>
                                @{
                                    var (cClass, cIcon, cLabel) = a.ComplianceStato switch {
                                        "ok"      => ("badge-ok",      "bi-check-circle",  "In Regola"),
                                        "warning" => ("badge-warning", "bi-clock",         "In Scadenza"),
                                        "danger"  => ("badge-danger",  "bi-exclamation-circle", "Scaduto"),
                                        "missing" => ("badge-missing", "bi-dash-circle",   "Da verificare"),
                                        _         => ("badge-missing", "bi-dash-circle",   "Da verificare")
                                    };
                                }
                                <span class="badge-compliance @cClass">
                                    <i class="bi @cIcon"></i> @cLabel
                                </span>
                            </td>

                            <!-- Prossimo Controllo -->
                            <td>
                                @if (a.ProssimaVerifica.HasValue)
                                {
                                    var giorni = (a.ProssimaVerifica.Value - oggi).Days;
                                    var colore = giorni < 0 ? "var(--danger)"
                                               : giorni <= 30 ? "var(--warning-dark)"
                                               : "var(--neutral-600)";
                                    <div style="font-size:0.85rem;
                                                font-weight:600;color:@colore">
                                        @a.ProssimaVerifica.Value.ToString("dd/MM/yyyy")
                                    </div>
                                    <div style="font-size:0.75rem;color:@colore">
                                        @if (giorni < 0)
                                        {
                                            <span>Scaduto @Math.Abs(giorni) gg fa</span>
                                        }
                                        else if (giorni == 0)
                                        {
                                            <span>Oggi</span>
                                        }
                                        else
                                        {
                                            <span>Tra @giorni giorni</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="color:var(--neutral-400);
                                                 font-size:0.85rem">—</span>
                                }
                            </td>

                            <!-- Azioni -->
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Apparecchiature/Detail/@a.Id"
                                       class="btn btn-ghost btn-icon btn-sm"
                                       title="Dettaglio">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="/Apparecchiature/Edit/@a.Id"
                                       class="btn btn-ghost btn-icon btn-sm"
                                       title="Modifica">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="/Apparecchiature/Stampa/@a.Id"
                                       target="_blank"
                                       class="btn btn-ghost btn-icon btn-sm"
                                       title="Stampa scheda">
                                        <i class="bi bi-printer"></i>
                                    </a>
                                    <form asp-action="Delete"
                                          asp-controller="Apparecchiature"
                                          asp-route-id="@a.Id"
                                          method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-ghost btn-icon btn-sm"
                                                title="Elimina (imposta Cessata)"
                                                data-confirm="Impostare come Cessata l'apparecchiatura @a.Descrizione?">
                                            <i class="bi bi-trash3 text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginazione -->
        @if (Model.TotalePagine > 1)
        {
            <div class="d-flex align-items-center justify-content-between
                        px-4 py-3"
                 style="border-top:1px solid var(--neutral-200);">
                <span style="font-size:0.825rem;color:var(--neutral-500)">
                    @((Model.PaginaCorrente - 1) * Model.ElementiPerPagina + 1)–@(Math.Min(Model.PaginaCorrente * Model.ElementiPerPagina, Model.TotaleRisultati))
                    di @Model.TotaleRisultati risultati
                </span>
                <div class="d-flex gap-1">
                    @for (int p = 1; p <= Model.TotalePagine; p++)
                    {
                        var q = $"?pagina={p}" +
                            (string.IsNullOrEmpty(Model.SearchText) ? "" : $"&search={Model.SearchText}") +
                            (string.IsNullOrEmpty(Model.StatoFiltro) ? "" : $"&stato={Model.StatoFiltro}") +
                            (string.IsNullOrEmpty(Model.AmbitoFiltro) ? "" : $"&ambito={Model.AmbitoFiltro}") +
                            (string.IsNullOrEmpty(Model.TipologiaFiltro) ? "" : $"&tipologia={Model.TipologiaFiltro}");
                        <a href="@q"
                           class="btn btn-sm @(p == Model.PaginaCorrente ? "btn-primary" : "btn-ghost")">
                            @p
                        </a>
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
<script>
// ─── TIPOLOGIE — aggiorna dropdown filtro quando cambia ambito ────
async function aggiornaTipologieFiltro(ambito) {
    const sel = document.getElementById('filtroTipologia');

    // ✅ SALVA VALORE ATTUALE
    const valoreSelezionato = sel.value;

    sel.innerHTML = '<option value="">Caricamento...</option>';
    sel.disabled = true;

    if (!ambito) {
        sel.innerHTML = '<option value="">Tutte</option>';
        sel.disabled = false;
        return;
    }

    try {
        const res  = await fetch(`/Apparecchiature/GetTipologiePerAmbito?ambito=${ambito}`);
        const data = await res.json();

        sel.innerHTML = '<option value="">Tutte</option>';

        data.forEach(t => {
            const opt = new Option(t, t);

            // ✅ RIPRISTINA SE ERA SELEZIONATO
            if (t === valoreSelezionato) {
                opt.selected = true;
            }

            sel.add(opt);
        });

        sel.disabled = false;

    } catch {
        sel.innerHTML = '<option value="">Tutte</option>';
        sel.disabled = false;
    }
}
document.addEventListener('DOMContentLoaded', function () {
    const ambito = document.getElementById('filtroAmbito')?.value;

    if (ambito) {
        aggiornaTipologieFiltro(ambito);
    }
});
</script>
}