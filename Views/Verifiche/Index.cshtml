@model RadiologiaAppNew.ViewModels.Verifiche.VerificaListViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Verifiche e Controlli di Qualità";
}

<!-- ═══ PAGE HEADER ══════════════════════════════════════════════ -->
<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-clipboard2-check me-2 text-primary"></i>
            Verifiche e Controlli di Qualità
        </h1>
        <p class="page-subtitle">
            @Model.TotaleRisultati verific@(Model.TotaleRisultati == 1 ? "a" : "he") trovat@(Model.TotaleRisultati == 1 ? "a" : "e")
            @if (Model.HaFiltriAttivi)
            {
                <span> — filtri attivi</span>
            }
        </p>
    </div>
    <div class="page-actions">
    @if (User.IsInRole("ADMIN_ORG") || User.IsInRole("EFM") ||
         User.IsInRole("EDR") || User.IsInRole("SFM"))
    {
        <!-- Se filtro apparecchiatura attivo → vai diretto al create -->
        @if (Model.ApparecchiaturaIdFiltro.HasValue)
        {
            <a href="/Verifiche/Create/@Model.ApparecchiaturaIdFiltro"
               class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Nuova Verifica
            </a>
        }
        else
        {
            <!-- Altrimenti vai prima a scegliere l'apparecchiatura -->
            <a href="/Apparecchiature" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Nuova Verifica
            </a>
            <div style="font-size:0.775rem;color:var(--neutral-500);
                        margin-top:4px;text-align:right;">
                Seleziona prima un'apparecchiatura
            </div>
        }
        
    }
    <a href="/Verifiche/ExportCsv?tipo=@Model.TipoFiltro&esito=@Model.EsitoFiltro&apparecchiaturaId=@Model.ApparecchiaturaIdFiltro"
   class="btn btn-ghost">
    <i class="bi bi-download"></i>
    Export CSV
</a>
</div>
</div>

<!-- ═══ KPI SCADENZE ═════════════════════════════════════════════ -->
@{
    var oggi        = DateTime.Today;
    var tra7        = oggi.AddDays(7);
    var tra30       = oggi.AddDays(30);
    var scadute     = Model.Verifiche.Count(v =>
        v.ProssimaVerificaData.HasValue &&
        v.ProssimaVerificaData < oggi);
    var entro7      = Model.Verifiche.Count(v =>
        v.ProssimaVerificaData.HasValue &&
        v.ProssimaVerificaData >= oggi &&
        v.ProssimaVerificaData <= tra7);
    var entro30     = Model.Verifiche.Count(v =>
        v.ProssimaVerificaData.HasValue &&
        v.ProssimaVerificaData > tra7 &&
        v.ProssimaVerificaData <= tra30);
    var superate    = Model.Verifiche.Count(v =>
        v.Esito == RadiologiaAppNew.Enums.EsitoVerifica.Positivo);
}

<div class="kpi-grid mb-4" style="grid-template-columns:repeat(4,1fr)">
    <div class="kpi-card kpi-danger">
        <div class="kpi-content">
            <div class="kpi-number">@scadute</div>
            <div class="kpi-label">Scadute</div>
            <div class="kpi-sublabel">Prossima verifica passata</div>
        </div>
        <i class="bi bi-x-circle kpi-icon"></i>
    </div>
    <div class="kpi-card kpi-warning">
        <div class="kpi-content">
            <div class="kpi-number">@entro7</div>
            <div class="kpi-label">Entro 7 giorni</div>
            <div class="kpi-sublabel">Urgenti</div>
        </div>
        <i class="bi bi-exclamation-triangle kpi-icon"></i>
    </div>
    <div class="kpi-card" style="border-left-color:var(--accent)">
        <div class="kpi-content">
            <div class="kpi-number">@entro30</div>
            <div class="kpi-label">Entro 30 giorni</div>
            <div class="kpi-sublabel">Da pianificare</div>
        </div>
        <i class="bi bi-clock kpi-icon"></i>
    </div>
    <div class="kpi-card kpi-success">
        <div class="kpi-content">
            <div class="kpi-number">@superate</div>
            <div class="kpi-label">Superate</div>
            <div class="kpi-sublabel">In questa vista</div>
        </div>
        <i class="bi bi-check-circle kpi-icon"></i>
    </div>
</div>

<!-- ═══ FILTRI ═══════════════════════════════════════════════════ -->
<div class="card mb-4">
    <div class="card-body" style="padding:16px 20px;">
        <form method="get" action="/Verifiche" id="formFiltri">
            <div class="row g-3 align-items-end">

                <div class="col-lg-3">
                    <label class="form-label">Cerca</label>
                    <div style="position:relative;">
                        <i class="bi bi-search"
                           style="position:absolute;left:10px;top:50%;
                                  transform:translateY(-50%);
                                  color:var(--neutral-500);
                                  font-size:0.85rem;"></i>
                        <input type="text" name="search"
                               value="@Model.SearchText"
                               class="form-control"
                               style="padding-left:32px;"
                               placeholder="Apparecchiatura, codice..."
                               autocomplete="off" />
                    </div>
                </div>

                <div class="col-lg-2">
                    <label class="form-label">Tipo Verifica</label>
                    <select name="tipo" class="form-select"
                            onchange="document.getElementById('formFiltri').submit()">
                        <option value="">Tutti i tipi</option>
                        @foreach (var t in Enum.GetValues<RadiologiaAppNew.Enums.TipoProtocollo>())
                        {
                           <option value="@t"
        selected="@(Model.TipoFiltro == t.ToString())">
    @t
</option>
                        }
                    </select>
                </div>

                <div class="col-lg-2">
                    <label class="form-label">Esito</label>
                    <select name="esito" class="form-select"
                            onchange="document.getElementById('formFiltri').submit()">
                        <option value="">Tutti gli esiti</option>
                        @foreach (var e in Enum.GetValues<RadiologiaAppNew.Enums.EsitoVerifica>())
                        {
                            <option value="@e"
        selected="@(Model.EsitoFiltro == e.ToString())">
    @e
</option>
                        }
                    </select>
                </div>

                <div class="col-lg-2">
                    <label class="form-label">Anno</label>
                    <select name="anno" class="form-select"
                            onchange="document.getElementById('formFiltri').submit()">
                        <option value="">Tutti gli anni</option>
                        @foreach (var a in Model.AnniDisponibili)
                        {
                            <option value="@a"
        selected="@(Model.AnnoFiltro == a)">
    @a
</option>

                        }
                    </select>
                </div>

                <div class="col-lg-2">
                    <label class="form-label">Apparecchiatura</label>
                    <select name="apparecchiaturaId" class="form-select"
                            onchange="document.getElementById('formFiltri').submit()">
                        <option value="">Tutte</option>
                        @foreach (var a in Model.Apparecchiature)
                        {
                            <option value="@a.Id"
        selected="@(Model.ApparecchiaturaIdFiltro == a.Id)">
    @a.Descrizione
</option>
                        }
                    </select>
                </div>

                <div class="col-lg-1 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-search"></i>
                    </button>
                    @if (Model.HaFiltriAttivi)
                    {
                        <a href="/Verifiche" class="btn btn-ghost"
                           title="Rimuovi filtri">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>

            </div>
        </form>
    </div>
</div>

<!-- ═══ TABELLA ══════════════════════════════════════════════════ -->
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-table card-icon"></i>
            Elenco Verifiche
        </h3>
        <span style="font-size:0.8rem;color:var(--neutral-500);">
            Pagina @Model.PaginaCorrente di @Model.TotalePagine
        </span>
    </div>

    @if (!Model.Verifiche.Any())
    {
        <div class="empty-state">
            <i class="bi bi-clipboard2 empty-state-icon"></i>
            <div class="empty-state-title">Nessuna verifica trovata</div>
            <p class="empty-state-text">
                @if (Model.HaFiltriAttivi)
                {
                    <span>Nessun risultato per i filtri selezionati.
                        <a href="/Verifiche">Rimuovi i filtri</a>
                    </span>
                }
                else
                {
                    <span>Non ci sono ancora verifiche registrate.
                        Seleziona un'apparecchiatura per aggiungerne una.
                    </span>
                }
            </p>
            <a href="/Apparecchiature" class="btn btn-primary btn-sm">
                <i class="bi bi-hdd-rack"></i>
                Vai alle Apparecchiature
            </a>
        </div>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table class="table-radiologia w-100">
                <thead>
                    <tr>
                        <th>Apparecchiatura</th>
                        <th>Tipo Verifica</th>
                        <th>Data Esecuzione</th>
                        <th>Esito</th>
                        <th>Anno</th>
                        <th>Prossima Verifica</th>
                        <th>Allegati</th>
                        <th style="width:90px;">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Verifiche)
                    {
                        var gg = v.ProssimaVerificaData.HasValue
                            ? (v.ProssimaVerificaData.Value.Date - oggi).Days
                            : (int?)null;

                        <tr class="clickable"
                            onclick="location.href='/Verifiche/Detail/@v.Id'">

                            <td>
                                <div class="fw-600">@v.Apparecchiatura</div>
                                <div style="font-size:0.775rem;
                                            color:var(--neutral-500);">
                                    @v.Protocollo
                                </div>
                            </td>

                            <td>
                                @{
                                    var (tipoColor, tipoIcon) = v.Tipo switch
                                    {
                                        RadiologiaAppNew.Enums.TipoProtocollo.Accettazione =>
                                            ("var(--primary)", "bi-check2-circle"),
                                        RadiologiaAppNew.Enums.TipoProtocollo.Periodico =>
                                            ("var(--secondary)", "bi-arrow-repeat"),
                                        RadiologiaAppNew.Enums.TipoProtocollo.Ldr =>
                                            ("var(--accent)", "bi-graph-up"),
                                        RadiologiaAppNew.Enums.TipoProtocollo.PostManutenzione =>
                                            ("var(--warning)", "bi-wrench"),
                                        RadiologiaAppNew.Enums.TipoProtocollo.PrimaVerificaEdr =>
                                            ("var(--primary-light)", "bi-person-check"),
                                        _ => ("var(--neutral-500)", "bi-clipboard2")
                                    };
                                }
                                <span style="font-size:0.825rem;
                                             color:@tipoColor;
                                             font-weight:600;">
                                    <i class="bi @tipoIcon me-1"></i>
                                    @v.Tipo
                                </span>
                            </td>

                            <td>
                                <span style="font-size:0.85rem;">
                                    @v.DataInizio.ToString("dd/MM/yyyy")
                                </span>
                                @if (v.DataFine.HasValue)
                                {
                                    <div style="font-size:0.75rem;
                                                color:var(--neutral-500);">
                                        → @v.DataFine.Value.ToString("dd/MM/yyyy")
                                    </div>
                                }
                            </td>

                            <td>
                                @{
                                    var (esitoClass, esitoIcon, esitoLabel) =
                                        v.Esito switch
                                    {
                                        
RadiologiaAppNew.Enums.EsitoVerifica.Positivo => ("badge-ok", "bi-check-circle", "Positivo"),
    RadiologiaAppNew.Enums.EsitoVerifica.Negativo => ("badge-danger", "bi-x-circle", "Negativo"),
    RadiologiaAppNew.Enums.EsitoVerifica.PositivoConRiserva => ("badge-warning", "bi-exclamation-circle", "Positivo con riserva"),
    _ => ("badge-missing", "bi-clock", "In Corso")

                                    };
                                }
                                <span class="badge-compliance @esitoClass">
                                    <i class="bi @esitoIcon"></i>
                                    @esitoLabel
                                </span>
                                @if (v.HaGuasto)
                                {
                                    <div style="margin-top:3px;">
                                        <span class="badge-compliance badge-danger"
                                              style="font-size:0.7rem;">
                                            <i class="bi bi-tools"></i>
                                            Guasto
                                        </span>
                                    </div>
                                }
                            </td>

                            <td>
                                <span style="font-size:0.85rem;">
                                    @(v.Anno?.ToString() ?? "—")
                                </span>
                                @if (!string.IsNullOrEmpty(v.Semestre))
                                {
                                    <div style="font-size:0.75rem;
                                                color:var(--neutral-500);">
                                        @v.Semestre
                                    </div>
                                }
                            </td>

                            <td>
                                @if (v.ProssimaVerificaData.HasValue)
                                {
                                    <span style="font-size:0.825rem;
                                                 font-weight:600;
                                                 color:@(gg < 0 ? "var(--danger)"
                                                         : gg <= 7 ? "var(--danger)"
                                                         : gg <= 30 ? "var(--warning)"
                                                         : "inherit")">
                                        @v.ProssimaVerificaData.Value
                                            .ToString("dd/MM/yyyy")
                                    </span>
                                    if (gg < 0)
                                    {
                                        <div style="font-size:0.7rem;
                                                    color:var(--danger);">
                                            Scaduta da @Math.Abs(gg!.Value) gg
                                        </div>
                                    }
                                    else if (gg <= 30)
                                    {
                                        <div style="font-size:0.7rem;
                                                    color:var(--warning);">
                                            Tra @gg giorni
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span style="color:var(--neutral-400);">—</span>
                                }
                            </td>

                            <td>
                                @if (v.NumeroAllegati > 0)
                                {
                                    <span class="badge-compliance badge-ok"
                                          style="font-size:0.75rem;">
                                        <i class="bi bi-paperclip"></i>
                                        @v.NumeroAllegati
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--neutral-400);
                                                 font-size:0.8rem;">—</span>
                                }
                            </td>

                            <td onclick="event.stopPropagation()">
                                <div class="d-flex gap-1">
                                    <a href="/Verifiche/Detail/@v.Id"
                                       class="btn btn-ghost btn-icon btn-sm"
                                       title="Visualizza"
                                       data-bs-toggle="tooltip">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("ADMIN_ORG") ||
                                         User.IsInRole("EFM") ||
                                         User.IsInRole("EDR") ||
                                         User.IsInRole("SFM"))
                                    {
                                        <a href="/Verifiche/Edit/@v.Id"
                                           class="btn btn-ghost btn-icon btn-sm"
                                           title="Modifica"
                                           data-bs-toggle="tooltip">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                </div>
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginazione -->
        @if (Model.TotalePagine > 1)
        {
            <div class="card-footer">
                <div class="pagination-radiologia">
                    @if (Model.PaginaCorrente > 1)
                    {
                        <a href="?pagina=@(Model.PaginaCorrente - 1)&search=@Model.SearchText&tipo=@Model.TipoFiltro&esito=@Model.EsitoFiltro&anno=@Model.AnnoFiltro&apparecchiaturaId=@Model.ApparecchiaturaIdFiltro"
                           class="page-btn">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    }
                    @for (int p = Math.Max(1, Model.PaginaCorrente - 2);
                          p <= Math.Min(Model.TotalePagine,
                                        Model.PaginaCorrente + 2); p++)
                    {
                        <a href="?pagina=@p&search=@Model.SearchText&tipo=@Model.TipoFiltro&esito=@Model.EsitoFiltro&anno=@Model.AnnoFiltro&apparecchiaturaId=@Model.ApparecchiaturaIdFiltro"
                           class="page-btn @(p == Model.PaginaCorrente
                               ? "active" : "")">
                            @p
                        </a>
                    }
                    @if (Model.PaginaCorrente < Model.TotalePagine)
                    {
                        <a href="?pagina=@(Model.PaginaCorrente + 1)&search=@Model.SearchText&tipo=@Model.TipoFiltro&esito=@Model.EsitoFiltro&anno=@Model.AnnoFiltro&apparecchiaturaId=@Model.ApparecchiaturaIdFiltro"
                           class="page-btn">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    }
                </div>
            </div>
        }
    }
</div>